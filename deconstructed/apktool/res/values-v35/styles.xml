<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme.Base" parent="@style/Theme.Material3.DayNight.NoActionBar">
        <item name="android:fitsSystemWindows">true</item>
        <item name="android:homeAsUpIndicator">@drawable/ic_outline_arrow_back_colortoolbartext_24dp</item>
        <item name="android:actionMenuTextColor">@color/color_primary_selector</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/colorM2DSurface</item>
        <item name="android:toolbarStyle">@style/Widget.App.Toolbar</item>
        <item name="android:windowLightStatusBar">@bool/lightStatusBar</item>
        <item name="android:windowLightNavigationBar">@bool/lightBottomNavigationBar</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="bottomNavigationStyle">@style/Widget.App.BottomNavigationView</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.App.BottomSheetDialog</item>
        <item name="elevationOverlayEnabled">false</item>
        <item name="homeAsUpIndicator">@drawable/ic_outline_arrow_back_colortoolbartext_24dp</item>
        <item name="materialCardViewStyle">@style/Widget.App.CardView</item>
        <item name="materialDividerStyle">@style/Widget.App.MaterialDivider</item>
        <item name="searchViewStyle">@style/SearchViewStyle</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.App.Button</item>
        <item name="toolbarStyle">@style/Widget.App.Toolbar</item>
    </style>
    <style name="ThemeOverlay.App.BottomSheetDialog" parent="@style/ThemeOverlay.Material3.BottomSheetDialog">
        <item name="enableEdgeToEdge">false</item>
    </style>
</resources>

<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:key="pref_screen_help">
    <Preference
        android:title="@string/about"
        app:iconSpaceReserved="false">
        <intent
            android:targetPackage="@string/app_id"
            android:action="android.intent.action.VIEW"
            android:targetClass="com.nandbox.view.settings.AboutAppActivity"/>
    </Preference>
    <Preference
        android:title="@string/faq"
        android:key="faq"
        app:iconSpaceReserved="false">
        <intent
            android:action="android.intent.action.VIEW"
            android:data="@string/faq_url"/>
    </Preference>
</PreferenceScreen>

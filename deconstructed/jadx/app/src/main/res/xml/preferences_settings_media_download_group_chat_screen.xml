            custome:noEntrySelectedSummary="@string/no_media"/>
        <com.nandbox.view.util.customViews.CustomSummaryMultiSelectListPreference
            android:entries="@array/entries_settings_media_download_media_group"
            android:title="@string/when_connected_to_wifi"
            android:key="media_download_group_other_wifi"
            android:defaultValue="@array/cons_media_download_group_other_wifi"
            android:entryValues="@array/entryvalues_settings_media_download_media_group"
            custome:iconSpaceReserved="false"
            custome:noEntrySelectedSummary="@string/no_media"/>
        <com.nandbox.view.util.customViews.CustomSummaryMultiSelectListPreference
            android:entries="@array/entries_settings_media_download_media_group"
            android:title="@string/when_roaming"
            android:key="media_download_group_other_roaming"
            android:defaultValue="@array/cons_media_download_group_other_roaming"
            android:entryValues="@array/entryvalues_settings_media_download_media_group"
            custome:iconSpaceReserved="false"
            custome:noEntrySelectedSummary="@string/no_media"/>

<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/markerBottomSheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="5dp"
    android:minHeight="40dp"
    android:layout_marginStart="5dp"
    android:layout_marginEnd="5dp"
    app:cardCornerRadius="5dp"
    app:cardElevation="10dp"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/url_image"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="135dp"
            android:scaleType="fitXY"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="normal"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/url_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:layout_marginBottom="7dp"
            android:maxWidth="170dp"
            android:minWidth="100dp"
            android:maxLines="1"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toTopOf="@+id/url_description"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/url_image"
            style="?android:attr/textViewStyle"/>
        <TextView
            android:textSize="12sp"
            android:textStyle="normal"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:id="@+id/url_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"
            android:maxWidth="170dp"
            android:minWidth="100dp"
            android:maxLines="2"
            android:fontFamily="sans-serif-light"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toTopOf="@+id/navigateOnGoogleMap"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/url_title"/>
        <androidx.cardview.widget.CardView
            android:id="@+id/navigateOnGoogleMap"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginLeft="5dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="@dimen/_8dp"
            android:minWidth="100dp"
            android:layout_marginStart="16dp"
            app:cardBackgroundColor="@color/colorSecondary"
            app:cardCornerRadius="14dp"
            app:cardElevation="5dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/url_description">
            <TextView
                android:textSize="13sp"
                android:textColor="?attr/colorOnSecondary"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/navigateOnGoogleMapText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/googleMap"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp"/>
        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:id="@+id/markerNext"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginLeft="8dp"
            android:minWidth="100dp"
            android:layout_marginStart="8dp"
            app:cardBackgroundColor="@color/colorSecondary"
            app:cardCornerRadius="14dp"
            app:cardElevation="5dp"
            app:layout_constraintBottom_toTopOf="@+id/navigateOnGoogleMap"
            app:layout_constraintStart_toEndOf="@+id/navigateOnGoogleMap"
            app:layout_constraintTop_toBottomOf="@+id/navigateOnGoogleMap">
            <TextView
                android:textSize="13sp"
                android:textColor="?attr/colorOnSecondary"
                android:layout_gravity="center"
                android:id="@+id/markerNextText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="check out"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp"/>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>

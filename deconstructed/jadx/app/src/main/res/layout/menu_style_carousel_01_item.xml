<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="4dp"
    android:layout_marginTop="4dp"
    android:layout_marginRight="4dp"
    android:layout_marginBottom="4dp"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp">
    <include
        android:id="@+id/headline_view"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        layout="@layout/menu_style_headline_01_item"/>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_gravity="center"
            android:orientation="vertical"
            android:id="@+id/main_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/list"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="196dp"
                android:choiceMode="singleChoice"/>
            <TextView
                android:textSize="14sp"
                android:layout_gravity="end"
                android:id="@+id/trailing_text"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@string/font_roboto_medium"
                android:layout_marginEnd="16dp"/>
        </LinearLayout>
        <TextView
            android:textSize="12sp"
            android:textColor="?attr/colorOnError"
            android:gravity="center"
            android:layout_gravity="end|top"
            android:id="@+id/unread_count_text"
            android:background="@drawable/circle_red_bg"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="2dp"
            android:minWidth="25dp"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"/>
    </FrameLayout>
</LinearLayout>

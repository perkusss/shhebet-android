<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:paddingBottom="@dimen/details_item_padding"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-3dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardUseCompatPadding="true"
        style="@style/NoCornersCardViewStyle">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_gravity="center"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_gravity="top|center_horizontal"
                android:orientation="vertical"
                android:id="@+id/main_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="70dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <LinearLayout
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="21sp"
                        android:textColor="?attr/colorOnSurface"
                        android:gravity="center"
                        android:layout_gravity="center_horizontal"
                        android:id="@+id/title_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@string/font_roboto_medium"/>
                    <ImageView
                        android:layout_gravity="center"
                        android:id="@+id/name_edit_image"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginStart="5dp"
                        app:srcCompat="@drawable/ic_edit_light_24dp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:id="@+id/desc_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="2"
                        android:fontFamily="@string/font_roboto"/>
                    <ImageView
                        android:layout_gravity="center"
                        android:id="@+id/desc_edit_image"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginStart="5dp"
                        app:srcCompat="@drawable/ic_edit_light_24dp"/>
                </LinearLayout>
            </LinearLayout>
            <Button
                android:id="@+id/publish_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp"
                android:text="@string/publish"
                android:layout_marginStart="32dp"
                android:layout_marginEnd="32dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/main_title"/>
            <Button
                android:id="@+id/invite_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp"
                android:text="@string/invite_to_connect"
                android:layout_marginStart="32dp"
                android:layout_marginEnd="32dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/main_title"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/chat_main_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/main_title">
                <ImageView
                    android:id="@+id/chat_icon"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    app:layout_constraintEnd_toStartOf="@+id/call_icon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/ic_chat_24dp"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="?attr/colorPrimary"
                    android:id="@+id/chat_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/message"
                    android:fontFamily="@string/font_roboto"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="@+id/chat_icon"
                    app:layout_constraintStart_toStartOf="@+id/chat_icon"
                    app:layout_constraintTop_toBottomOf="@+id/chat_icon"/>
                <ImageView
                    android:id="@+id/call_icon"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    app:layout_constraintEnd_toStartOf="@+id/video_icon"
                    app:layout_constraintStart_toEndOf="@+id/chat_icon"
                    app:layout_constraintTop_toTopOf="@+id/chat_icon"
                    app:srcCompat="@drawable/ic_call_24dp"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="?attr/colorPrimary"
                    android:id="@+id/call_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/call"
                    android:fontFamily="@string/font_roboto"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="@+id/call_icon"
                    app:layout_constraintStart_toStartOf="@+id/call_icon"
                    app:layout_constraintTop_toBottomOf="@+id/call_icon"/>
                <ImageView
                    android:id="@+id/video_icon"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    app:layout_constraintEnd_toStartOf="@+id/mute_icon"
                    app:layout_constraintStart_toEndOf="@+id/call_icon"
                    app:layout_constraintTop_toTopOf="@+id/call_icon"
                    app:srcCompat="@drawable/ic_video_24dp"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="?attr/colorPrimary"
                    android:id="@+id/video_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/video"
                    android:fontFamily="@string/font_roboto"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="@+id/video_icon"
                    app:layout_constraintStart_toStartOf="@+id/video_icon"
                    app:layout_constraintTop_toBottomOf="@+id/video_icon"/>
                <ImageView
                    android:id="@+id/mute_icon"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/video_icon"
                    app:layout_constraintTop_toTopOf="@+id/video_icon"
                    app:srcCompat="@drawable/ic_notifications_colorprimary_24dp"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="?attr/colorPrimary"
                    android:id="@+id/mute_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/mute"
                    android:fontFamily="@string/font_roboto"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="@+id/mute_icon"
                    app:layout_constraintStart_toStartOf="@+id/mute_icon"
                    app:layout_constraintTop_toBottomOf="@+id/mute_icon"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>

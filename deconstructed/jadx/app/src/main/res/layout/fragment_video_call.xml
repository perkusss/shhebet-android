<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rl_video_containers"
        android:layout_width="0px"
        android:layout_height="0px"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <FrameLayout
            android:id="@+id/frm_remote_video_container"
            android:layout_width="0px"
            android:layout_height="0px"
            app:layout_constraintBottom_toTopOf="@+id/frm_local_video_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_weight="1">
            <ImageView
                android:id="@+id/img_peer_profile"
                android:background="#c1c9be"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scaleType="centerCrop"/>
            <FrameLayout
                android:id="@+id/frm_remote_video_holder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <RelativeLayout
                android:id="@+id/rl_with_container"
                android:background="@color/colorTransparentBlack80"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <TextView
                    android:textSize="14sp"
                    android:textColor="#ffffff"
                    android:id="@+id/txt_call_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="16dp"
                    android:text="@string/ringing"
                    android:layout_alignParentBottom="true"
                    android:layout_centerHorizontal="true"
                    android:fontFamily="@string/font_roboto"/>
                <TextView
                    android:textSize="34sp"
                    android:textColor="#ffffff"
                    android:ellipsize="end"
                    android:id="@+id/txt_with"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:text="Nelle Griffin"
                    android:lines="1"
                    android:layout_above="@+id/txt_call_status"
                    android:layout_centerHorizontal="true"
                    android:fontFamily="@string/font_roboto_light"/>
            </RelativeLayout>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/frm_local_video_container"
            android:layout_width="0px"
            android:layout_height="0px"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/frm_remote_video_container"
            app:layout_constraintVertical_weight="1">
            <ImageView
                android:id="@+id/img_my_profile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <FrameLayout
                android:id="@+id/frm_local_video_holder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <ImageView
                android:layout_gravity="end|top"
                android:id="@+id/img_minimize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:srcCompat="@drawable/ic_baseline_fullscreen_24dp"/>
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <FrameLayout
        android:id="@+id/frm_statusbar_bg"
        android:background="@color/colorTransparentBlack4c"
        android:layout_width="0px"
        android:layout_height="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <RelativeLayout
        android:id="@+id/ll_mini_and_controls_container"
        android:background="@android:color/transparent"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <FrameLayout
            android:id="@+id/frm_local_mini_video_container"
            android:layout_width="100dp"
            android:layout_height="140dp"
            android:layout_alignParentEnd="true">
            <ImageView
                android:id="@+id/img_mini_my_profile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <FrameLayout
                android:id="@+id/frm_mini_local_video_holder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <ImageView
                android:layout_gravity="end|top"
                android:id="@+id/img_maximize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="3dp"
                app:srcCompat="@drawable/ic_baseline_fullscreen_24dp"/>
        </FrameLayout>
        <LinearLayout
            android:layout_gravity="bottom|center_horizontal"
            android:orientation="horizontal"
            android:id="@+id/ll_call_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:weightSum="5"
            android:layout_below="@+id/frm_local_mini_video_container"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp">
            <FrameLayout
                android:id="@+id/frm_mute_video_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/img_mute_video"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:srcCompat="@drawable/ic_videocam_off_white_56_dp"/>
            </FrameLayout>
            <FrameLayout
                android:id="@+id/frm_img_mic_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/img_mic"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:srcCompat="@drawable/ic_mic_off_56_dp"/>
            </FrameLayout>
            <FrameLayout
                android:id="@+id/frm_front_camera_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/img_front_camera"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:srcCompat="@drawable/ic_switch_camera_white_56_dp"/>
            </FrameLayout>
            <FrameLayout
                android:id="@+id/frm_bluetooth_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/img_bluetooth"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:srcCompat="@drawable/ic_switch_bluetooth_inactive_white_56_dp"/>
            </FrameLayout>
            <FrameLayout
                android:id="@+id/frm_end_call_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/img_end_call"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:srcCompat="@drawable/ic_call_end_60dp"/>
            </FrameLayout>
        </LinearLayout>
    </RelativeLayout>
    <FrameLayout
        android:id="@+id/frm_all_screen_dimmed"
        android:background="@color/colorTransparentBlack80"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:textSize="14sp"
            android:textColor="#ffffff"
            android:layout_gravity="center"
            android:background="@drawable/button_white_rounded_bg"
            android:paddingLeft="24dp"
            android:paddingTop="10dp"
            android:paddingRight="24dp"
            android:paddingBottom="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/call_on_hold"
            android:fontFamily="@string/font_roboto_medium"/>
    </FrameLayout>
    <FrameLayout
        android:id="@+id/frm_navigator_bg"
        android:background="#000000"
        android:layout_width="0px"
        android:layout_height="0px"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:id="@+id/parent_view"
    android:focusable="true"
    android:clickable="true"
    android:descendantFocusability="blocksDescendants"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:layout_gravity="center_horizontal"
        android:id="@+id/container_view"
        android:background="?attr/selectableItemBackground"
        android:paddingLeft="15dp"
        android:paddingRight="15dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/view_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@+id/picture_view"
            android:layout_alignParentStart="true"
            android:layout_marginVertical="8dp">
            <github.ankushsachdeva.emojicon.EmojiconTextView
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"
                android:ellipsize="end"
                android:gravity="start|center_vertical"
                android:layout_gravity="start"
                android:id="@+id/notification_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="3dp"
                android:text="@string/group_notification_text"
                android:maxLines="2"
                android:fontFamily="@string/font_roboto"
                android:textDirection="locale"
                app:emojiconSize="@dimen/message_emoji_size"/>
            <LinearLayout
                android:layout_gravity="start"
                android:orientation="horizontal"
                android:id="@+id/message_header"
                android:focusableInTouchMode="false"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/message_status_icon"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:layout_marginEnd="9dp"
                    app:srcCompat="@drawable/ic_notifications_time_16dp"/>
                <TextView
                    android:textSize="16sp"
                    android:textStyle="normal"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_gravity="start|center_vertical"
                    android:id="@+id/message_board_date"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10:00 pm"
                    android:singleLine="true"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_gravity="end|center_vertical"
            android:id="@+id/picture_view"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="15dp"
            android:layout_alignParentEnd="true">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/image_icon_res"
                android:visibility="gone"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="fitXY"/>
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/profile_icon"
                android:visibility="gone"
                android:duplicateParentState="true"
                android:layout_width="50dp"
                android:layout_height="50dp"
                app:srcCompat="@drawable/ic_contact_130dp"/>
            <androidx.cardview.widget.CardView
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/image_corner_Radius"
                app:cardElevation="0dp">
                <ImageView
                    android:id="@+id/image_icon"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleType="fitXY"/>
                <ImageView
                    android:layout_gravity="end|bottom"
                    android:id="@+id/image_media_icon_res"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:scaleType="fitXY"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </RelativeLayout>
    <com.google.android.material.divider.MaterialDivider
        android:layout_gravity="bottom"
        android:id="@+id/item_divider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</FrameLayout>

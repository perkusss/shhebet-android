<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:visibility="visible"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent">
        <com.joooonho.SelectableRoundedImageView
            android:id="@+id/url_image"
            android:visibility="visible"
            android:layout_width="70dp"
            android:layout_height="0dp"
            android:layout_marginBottom="4dp"
            android:scaleType="center"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/url_title"
            app:sriv_left_bottom_corner_radius="5dp"
            app:sriv_left_top_corner_radius="5dp"
            app:sriv_right_bottom_corner_radius="5dp"
            app:sriv_right_top_corner_radius="5dp"/>
        <ImageView
            android:id="@+id/play_icon_image"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:layout_centerInParent="true"
            android:layout_marginStart="8dp"
            app:layout_constraintBottom_toBottomOf="@+id/url_image"
            app:layout_constraintEnd_toEndOf="@+id/url_image"
            app:layout_constraintHorizontal_bias="0.478"
            app:layout_constraintStart_toStartOf="@+id/url_image"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_video_youtube_85dp"/>
        <TextView
            android:textSize="12sp"
            android:textStyle="normal"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:id="@+id/url_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:maxWidth="170dp"
            android:minWidth="100dp"
            android:maxLines="2"
            android:fontFamily="sans-serif-light"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/url_image"
            app:layout_constraintTop_toBottomOf="@+id/url_title"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/colorTransparentBlack33"
            android:id="@+id/site_name"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxWidth="170dp"
            android:fontFamily="@string/font_roboto"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/url_description"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="normal"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/url_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:maxWidth="170dp"
            android:minWidth="100dp"
            android:maxLines="1"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/url_image"
            app:layout_constraintTop_toTopOf="parent"
            style="?android:attr/textViewStyle"/>
        <Button
            android:id="@+id/next"
            android:background="@drawable/ic_next_24_dp"
            android:visibility="gone"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginLeft="8dp"
            android:layout_marginStart="8dp"
            app:layout_constraintBottom_toTopOf="@+id/navigate"
            app:layout_constraintStart_toEndOf="@+id/navigate"
            app:layout_constraintTop_toBottomOf="@+id/navigate"/>
        <Button
            android:id="@+id/navigate"
            android:background="@drawable/ic_nav_24_dp"
            android:visibility="gone"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginLeft="5dp"
            android:layout_marginTop="8dp"
            android:layout_marginRight="8dp"
            android:layout_marginBottom="5dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/url_title"
            app:layout_constraintTop_toBottomOf="@+id/url_description"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>

<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:background="@drawable/bg_inline_reply_outgoing_bg"
    app:cardElevation="0dp">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <View
            android:id="@+id/v_inline_reply_left"
            android:background="@color/colorMOnPrimaryContainer"
            android:layout_width="3dp"
            android:layout_height="match_parent"/>
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <github.ankushsachdeva.emojicon.EmojiconTextView
                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:ellipsize="end"
                android:gravity="start"
                android:id="@+id/txt_reply_profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Someone"
                android:lines="1"
                android:layout_alignParentTop="true"
                android:layout_centerHorizontal="true"
                android:fontFamily="@string/font_roboto"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                app:emojiconSize="14sp"/>
            <ImageView
                android:id="@+id/img_media"
                android:layout_width="@dimen/inline_reply_img_width"
                android:layout_height="@dimen/inline_reply_img_width"
                android:layout_margin="4dp"
                android:scaleType="centerCrop"
                android:layout_below="@+id/txt_reply_profile_name"
                android:layout_centerHorizontal="true"/>
        </RelativeLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="1dp">
    <ImageView
        android:id="@+id/img_image"
        android:background="?attr/colorOutlineVariant"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_document_50dp"
        app:tint="?attr/colorSurface"/>
    <TextView
        android:textSize="13sp"
        android:textColor="?attr/colorOnSurfaceInverse"
        android:id="@+id/txt_size"
        android:background="@drawable/bg_storage_size"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="122 KB"
        android:fontFamily="@string/font_roboto"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginStart="4dp"
        app:layout_constraintStart_toStartOf="@+id/img_image"
        app:layout_constraintTop_toTopOf="@+id/img_image"/>
    <FrameLayout
        android:id="@+id/frm_selected"
        android:background="@color/colorTransparentBlack80"
        android:visibility="gone"
        android:layout_width="0px"
        android:layout_height="0px"
        app:layout_constraintBottom_toBottomOf="@+id/img_image"
        app:layout_constraintEnd_toEndOf="@+id/img_image"
        app:layout_constraintStart_toStartOf="@+id/img_image"
        app:layout_constraintTop_toTopOf="@+id/img_image">
        <ImageView
            android:layout_gravity="end|bottom"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginBottom="10dp"
            android:layout_marginEnd="10dp"
            app:srcCompat="@drawable/ic_check_media_storage_20dp"/>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

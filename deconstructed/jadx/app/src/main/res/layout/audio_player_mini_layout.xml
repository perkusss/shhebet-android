<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="?attr/colorSurfaceDim"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/audio_image_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@+id/audio_seekbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/audio_image"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:scaleType="centerCrop"
            app:srcCompat="@drawable/ic_headphones_46dp"/>
    </com.google.android.material.card.MaterialCardView>
    <TextView
        android:textSize="16sp"
        android:ellipsize="end"
        android:id="@+id/audio_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:lines="1"
        android:fontFamily="@string/font_roboto_medium"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toStartOf="@+id/audio_play_pause_button"
        app:layout_constraintStart_toEndOf="@+id/audio_image_view"
        app:layout_constraintTop_toTopOf="@+id/audio_image_view"/>
    <TextView
        android:textSize="14sp"
        android:ellipsize="end"
        android:id="@+id/audio_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:lines="1"
        android:fontFamily="@string/font_roboto"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toStartOf="@+id/audio_play_pause_button"
        app:layout_constraintStart_toEndOf="@+id/audio_image_view"
        app:layout_constraintTop_toBottomOf="@+id/audio_title"/>
    <ImageView
        android:id="@+id/audio_play_pause_button"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/audio_close_button"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.35"
        app:srcCompat="@drawable/ic_pause_circle_primary_38dp"/>
    <ImageView
        android:id="@+id/audio_close_button"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.35"
        app:srcCompat="@drawable/ic_close_circle_30dp"/>
    <androidx.appcompat.widget.AppCompatSeekBar
        android:id="@+id/audio_seekbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:max="100"
        android:progress="10"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@android:color/black"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include
        android:id="@+id/tool_bar"
        layout="@layout/tool_bar"/>
    <ImageView
        android:id="@+id/img_thumb"
        android:layout_width="160dp"
        android:layout_height="160dp"
        app:layout_constraintBottom_toTopOf="@+id/img_play"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tool_bar"
        app:srcCompat="@drawable/ic_voice_white_160dp"
        app:tint="@android:color/white"/>
    <ImageView
        android:id="@+id/img_play"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginBottom="60dp"
        android:layout_marginStart="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/play_recording_preview_16dp"
        app:tint="@android:color/white"/>
    <SeekBar
        android:id="@+id/seek_bar"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        android:progress="0"
        android:thumbOffset="1dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintBottom_toBottomOf="@+id/img_play"
        app:layout_constraintEnd_toStartOf="@+id/txt_progress_time"
        app:layout_constraintStart_toEndOf="@+id/img_play"
        app:layout_constraintTop_toTopOf="@+id/img_play"
        style="@style/SeekbarCustomProgressBarHorizontalStorageAudio"/>
    <TextView
        android:textSize="18sp"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:id="@+id/txt_progress_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="4:56"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="@+id/img_play"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/img_play"/>
</androidx.constraintlayout.widget.ConstraintLayout>

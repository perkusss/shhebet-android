<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/toolbar_container"
        android:background="?attr/nand_colorM3Surface"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/tool_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:popupTheme="@style/Widget.App.PopupMenu.Overflow"/>
    </com.google.android.material.appbar.AppBarLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cns_container"
        android:background="?attr/colorSurface"
        android:layout_width="0px"
        android:layout_height="0px"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar_container">
        <androidx.cardview.widget.CardView
            android:id="@+id/search_edit_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginRight="8dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:cardElevation="@dimen/card_elevation"
            app:cardUseCompatPadding="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <github.ankushsachdeva.emojicon.EmojiconEditText
                android:scrollbarStyle="outsideInset"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"
                android:id="@+id/search_edit_text"
                android:background="?attr/colorSurfaceContainerLowest"
                android:padding="14dp"
                android:scrollbars="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="32dp"
                android:hint="@string/search_hint"
                android:maxLines="1"
                android:scrollHorizontally="false"
                android:inputType="textAutoCorrect"
                android:imeOptions="actionSearch"
                app:emojiconSize="24sp"/>
        </androidx.cardview.widget.CardView>
        <HorizontalScrollView
            android:scrollbarSize="0dp"
            android:id="@+id/view3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/search_edit_view">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn1_view"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:layout_marginStart="8dp"
                    app:cardElevation="@dimen/card_elevation"
                    app:cardUseCompatPadding="true">
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@+id/btn1"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="8dp"
                        android:clickable="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:id="@+id/btn1_icon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginRight="1dp"
                            android:layout_marginEnd="1dp"
                            app:srcCompat="@drawable/ic_location_24dp"
                            app:tint="?attr/colorOnSurfaceVariant"/>
                        <TextView
                            android:textSize="14sp"
                            android:id="@+id/btn1_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@string/font_roboto"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn2_view"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardElevation="@dimen/card_elevation"
                    app:cardUseCompatPadding="true">
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@+id/btn2"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="8dp"
                        android:clickable="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:id="@+id/btn2_icon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginRight="1dp"
                            android:layout_marginEnd="1dp"
                            app:srcCompat="@drawable/ic_location_24dp"
                            app:tint="?attr/colorOnSurfaceVariant"/>
                        <TextView
                            android:textSize="14sp"
                            android:id="@+id/btn2_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@string/font_roboto"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn3_view"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="16dp"
                    android:layout_marginEnd="16dp"
                    app:cardElevation="@dimen/card_elevation"
                    app:cardUseCompatPadding="true">
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@+id/btn3"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="8dp"
                        android:clickable="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:id="@+id/btn3_icon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginRight="1dp"
                            android:layout_marginEnd="1dp"
                            app:srcCompat="@drawable/ic_location_24dp"
                            app:tint="?attr/colorOnSurfaceVariant"/>
                        <TextView
                            android:textSize="14sp"
                            android:id="@+id/btn3_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@string/font_roboto"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </HorizontalScrollView>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/select_date_view"
            android:background="?attr/colorSurfaceContainer"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/view3">
            <ImageView
                android:id="@+id/imageView7"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_calendar_24dp"/>
            <TextView
                android:textSize="11sp"
                android:textStyle="normal"
                android:textColor="?attr/colorOnSurface"
                android:ellipsize="end"
                android:gravity="start"
                android:id="@+id/date_title_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Monday, 12 February"
                android:lineSpacingExtra="8sp"
                android:fontFamily="@string/font_roboto"
                android:layout_marginStart="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/imageView8"
                app:layout_constraintStart_toEndOf="@+id/imageView7"
                app:layout_constraintTop_toTopOf="parent"/>
            <ImageView
                android:id="@+id/imageView8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_arrow_dark_right_24dp"
                app:tint="?attr/colorOnSurfaceVariant"/>
            <com.google.android.material.divider.MaterialDivider
                android:id="@+id/view23"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_gravity="center"
            android:id="@+id/spinner"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/rcy_search_result"
            app:layout_constraintEnd_toEndOf="@+id/rcy_search_result"
            app:layout_constraintStart_toStartOf="@+id/rcy_search_result"
            app:layout_constraintTop_toTopOf="@+id/rcy_search_result"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/no_result_view"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/rcy_search_result"
            app:layout_constraintEnd_toEndOf="@+id/rcy_search_result"
            app:layout_constraintStart_toStartOf="@+id/rcy_search_result"
            app:layout_constraintTop_toTopOf="@+id/rcy_search_result"
            app:layout_constraintVertical_bias="0.35">
            <ImageView
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:srcCompat="@drawable/ic_search_no_result_80dp"
                app:tint="?attr/colorOutlineVariant"/>
            <TextView
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/no_results_found"
                android:fontFamily="@string/font_roboto_medium"/>
            <TextView
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="50dp"
                android:layout_marginTop="8dp"
                android:layout_marginRight="50dp"
                android:text="@string/please_try_different_keywords"
                android:fontFamily="@string/font_roboto"
                android:layout_marginStart="50dp"
                android:layout_marginEnd="50dp"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/no_connection_view"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/rcy_search_result"
            app:layout_constraintEnd_toEndOf="@+id/rcy_search_result"
            app:layout_constraintStart_toStartOf="@+id/rcy_search_result"
            app:layout_constraintTop_toTopOf="@+id/rcy_search_result"
            app:layout_constraintVertical_bias="0.35">
            <ImageView
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:srcCompat="@drawable/ic_no_connection_120dp"/>
            <TextView
                android:textSize="17sp"
                android:textStyle="normal"
                android:textColor="?attr/colorOnSurface"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:text="@string/no_internet_connection_error"
                android:fontFamily="@string/font_roboto_medium"
                android:letterSpacing="0.01"/>
            <TextView
                android:textSize="14sp"
                android:textStyle="normal"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:text="@string/check_your_internet_connection"
                android:fontFamily="@string/font_roboto_light"
                android:layout_marginStart="50dp"
                android:layout_marginEnd="50dp"
                android:letterSpacing="0.01"/>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcy_search_result"
            android:background="?attr/colorSurface"
            android:paddingBottom="5dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:choiceMode="singleChoice"
            android:splitMotionEvents="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/select_date_view"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

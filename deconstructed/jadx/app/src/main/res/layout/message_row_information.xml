<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:background="?attr/selectableItemBackground"
    android:descendantFocusability="blocksDescendants"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/image_container"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:paddingTop="11dp"
        android:paddingBottom="11dp"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="14dp">
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/contact_icon"
            android:layout_width="54dp"
            android:layout_height="54dp"/>
        <ImageView
            android:layout_gravity="end|bottom"
            android:id="@+id/verified_icon"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            app:srcCompat="@drawable/ic_verified_green_18dp"/>
    </FrameLayout>
    <RelativeLayout
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="84dp"
        android:layout_marginEnd="16dp">
        <RelativeLayout
            android:id="@+id/profile_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="0dp"
            android:layout_toStartOf="@+id/message_date"
            android:layout_toEndOf="@null"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="false">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/name_info_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentEnd="false">
                <ImageView
                    android:id="@+id/chat_type_icon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="0dp"
                    android:layout_marginEnd="8dp"
                    app:srcCompat="@drawable/ic_outline_channel_18dp"/>
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:id="@+id/img_muted"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_volume_off_colorsecondarytext_18dp"
                            app:tint="?attr/colorOnSurfaceVariant"/>
                        <TextView
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:ellipsize="end"
                            android:gravity="start"
                            android:id="@+id/contact_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mike Cryst"
                            android:lines="1"
                            android:textDirection="firstStrong"
                            android:layout_marginEnd="4dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/img_muted"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </FrameLayout>
                <TextView
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="start"
                    android:id="@+id/message_relationship"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Family"
                    android:lines="1"/>
            </LinearLayout>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/chat_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_below="@+id/profile_info"
            android:layout_marginEnd="6dp"
            android:layout_toStartOf="@+id/item_settings_view"
            android:layout_toEndOf="@null">
            <TextView
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:gravity="start"
                android:layout_gravity="start"
                android:id="@+id/typing_message"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="20dp"
                android:text="@string/typing_message"
                android:singleLine="true"/>
            <LinearLayout
                android:id="@+id/ll_last_message"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentEnd="false">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/message_content_icon"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:layout_marginEnd="2dp"
                    app:srcCompat="@drawable/ic_outline_access_time_colorprimarytext_18dp"/>
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/message_type_icon"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginStart="0dp"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="start"
                    android:layout_gravity="start"
                    android:id="@+id/group_sender"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/name"
                    android:singleLine="true"
                    android:layout_marginStart="0dp"
                    android:layout_marginEnd="4dp"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="start"
                    android:layout_gravity="start"
                    android:id="@+id/colon"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text=":"
                    android:layout_marginStart="0dp"
                    android:layout_marginEnd="4dp"/>
                <github.ankushsachdeva.emojicon.EmojiconTextView
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textColorLink="@color/colorLinkText"
                    android:id="@+id/last_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:singleLine="true"
                    android:textDirection="firstStrong"
                    android:layout_marginStart="0dp"
                    android:layout_marginEnd="4dp"
                    app:emojiconSize="16sp"/>
            </LinearLayout>
        </RelativeLayout>
        <TextView
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:id="@+id/message_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10 Hours ago"
            android:layout_alignParentStart="false"
            android:layout_alignParentEnd="true"/>
        <LinearLayout
            android:id="@+id/item_settings_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@+id/chat_desc"
            android:layout_alignParentBottom="false"
            android:layout_alignParentStart="false"
            android:layout_alignParentEnd="true">
            <ImageView
                android:id="@+id/pin_icon"
                android:visibility="gone"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="6dp"
                app:srcCompat="@drawable/ic_pin_black_colorsecondarytext_18dp"
                app:tint="?attr/colorOnSurfaceVariant"/>
            <ImageView
                android:id="@+id/high_priority_icon"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                app:srcCompat="@drawable/ic_star_yellow_18dp"/>
            <TextView
                android:textColor="?attr/colorOnPrimary"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/unread_message_count"
                android:background="@drawable/unread_message_background_item"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="20dp"
                android:text="0"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"/>
        </LinearLayout>
    </RelativeLayout>
    <com.google.android.material.divider.MaterialDivider
        android:layout_gravity="bottom"
        android:id="@+id/item_divider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="85dp"/>
</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cor_root"
    android:background="?attr/colorSurface"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/toolbar_container"
        android:background="?attr/nand_colorM3Surface"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/tool_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:popupTheme="@style/Widget.App.PopupMenu.Overflow"/>
            <com.nandbox.view.util.materialsearchview.MaterialSearchView
                android:textColor="@color/colorM2OnSurface"
                android:textColorHint="@color/colorM2OnSurfaceVariant"
                android:id="@+id/search_view"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:hint="@string/search_hint"
                android:layout_marginStart="4dp"
                app:searchBackIcon="@drawable/ic_outline_arrow_back_colortoolbartext_24dp"
                app:searchBackground="@color/colorM2ASurface"
                app:searchCloseIcon="@drawable/ic_close_white_24_dp"/>
        </FrameLayout>
    </com.google.android.material.appbar.AppBarLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cns_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <androidx.cardview.widget.CardView
            android:id="@+id/crd_map"
            android:layout_width="0px"
            android:layout_height="0px"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardPreventCornerOverlap="true"
            app:cardUseCompatPadding="false"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <fragment
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:id="@+id/map"
                    android:layout_width="0px"
                    android:layout_height="0px"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <androidx.constraintlayout.widget.Guideline
                    android:orientation="horizontal"
                    android:id="@+id/gud_50"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="@+id/map"
                    app:layout_constraintGuide_percent="0.5"
                    app:layout_constraintStart_toStartOf="@+id/map"/>
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_marker_dot"
                    android:background="?attr/colorOnSurface"
                    android:visibility="gone"
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    app:layout_constraintBottom_toBottomOf="@+id/gud_50"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/gud_50"
                    app:shapeAppearance="@style/ShapeAppearance.Circle"/>
                <ImageView
                    android:id="@+id/img_marker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@+id/gud_50"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:srcCompat="@drawable/ic_marker_23dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_enlarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="16dp"
                    app:icon="@drawable/ic_enlarge_24dp"
                    app:iconTint="?attr/colorOnSurface"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    style="@style/App.MapButton.Widget.Material3.Button.IconButton.Filled"/>
                <com.google.android.material.button.MaterialButton
                    android:enabled="false"
                    android:id="@+id/btn_my_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="16dp"
                    app:icon="@drawable/ic_mylocation_24dp"
                    app:iconTint="?attr/colorOnSurface"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    style="@style/App.MapButton.Widget.Material3.Button.IconButton.Filled"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_map_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="16dp"
                    app:icon="@drawable/ic_map_type_24dp"
                    app:iconTint="?attr/colorOnSurface"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/btn_my_location"
                    app:layout_goneMarginTop="16dp"
                    style="@style/App.MapButton.Widget.Material3.Button.IconButton.Filled"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>
        <FrameLayout
            android:id="@+id/frm_current_location"
            android:background="@drawable/bg_curved_surfacecontainer_16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/crd_map">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cns_current_location"
                android:background="?attr/selectableItemBackground"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_icon"
                    android:background="@color/colorCurrentLocationBg"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:scaleType="center"
                    android:layout_marginStart="16dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:shapeAppearance="@style/ShapeAppearance.Circle"
                    app:srcCompat="@drawable/ic_location_24dp"/>
                <TextView
                    android:textSize="16sp"
                    android:textColor="@color/primary_text_color_selector"
                    android:id="@+id/lbl_send_current_location"
                    android:layout_width="0px"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/Send_your_current_location"
                    android:fontFamily="@string/font_roboto"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/img_icon"
                    app:layout_constraintTop_toTopOf="parent"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/secondary_text_color_selector"
                    android:ellipsize="end"
                    android:id="@+id/lbl_current_location_accuracy"
                    android:layout_width="0px"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"
                    android:lines="1"
                    android:fontFamily="@string/font_roboto"
                    android:textAlignment="viewStart"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/img_icon"
                    app:layout_constraintTop_toBottomOf="@+id/lbl_send_current_location"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_places_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="3dp"
        app:backgroundTint="?attr/colorSurface"
        app:behavior_peekHeight="200dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        style="@style/Widget.Material3.BottomSheet">
        <com.google.android.material.bottomsheet.BottomSheetDragHandleView
            android:id="@+id/drag_handle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <TextView
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/lbl_or_choose_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/choose_place_title"
            android:fontFamily="@string/font_roboto_medium"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcy_places"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:overScrollMode="never"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>
    </LinearLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cns_map_type_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="3dp"
        app:backgroundTint="?attr/colorSurface"
        app:behavior_peekHeight="auto"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        style="@style/Widget.Material3.BottomSheet">
        <TextView
            android:textSize="16sp"
            android:id="@+id/lbl_choose_map"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="@string/Choose_map"
            android:fontFamily="@string/font_roboto_medium"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toStartOf="@+id/btn_close_map_type"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_close_map_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            app:icon="@drawable/ic_close_black_24dp"
            app:iconTint="?attr/colorOnSurface"
            app:layout_constraintBottom_toBottomOf="@+id/lbl_choose_map"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/lbl_choose_map"
            app:layout_goneMarginTop="16dp"
            style="@style/App.MapButton.Widget.Material3.Button.IconButton.Filled.BgSurfaceContainer"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/ll_default"
            android:background="@drawable/bg_curved_surfacecontainer_16dp_border"
            android:padding="2dp"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/ll_satellite"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/lbl_choose_map">
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/img_map_type_default"
                android:layout_width="0px"
                android:layout_height="0px"
                android:scaleType="centerInside"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearance="@style/ShapeAppearance.CurvedTop16DP"
                app:srcCompat="@drawable/ic_map_style_defualt_122dp"/>
            <TextView
                android:textSize="16sp"
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:text="@string/default_text"
                android:maxLines="1"
                android:fontFamily="@string/font_roboto_medium"
                android:textAlignment="center"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/img_map_type_default"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/ll_satellite"
            android:background="@drawable/bg_curved_surfacecontainer_16dp"
            android:padding="2dp"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/ll_hybrid"
            app:layout_constraintStart_toEndOf="@+id/ll_default"
            app:layout_constraintTop_toBottomOf="@+id/lbl_choose_map">
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/img_map_type_satellite"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:scaleType="centerInside"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearance="@style/ShapeAppearance.CurvedTop16DP"
                app:srcCompat="@drawable/ic_map_style_satellite_122dp"/>
            <TextView
                android:textSize="16sp"
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:text="@string/satellite"
                android:maxLines="1"
                android:fontFamily="@string/font_roboto_medium"
                android:textAlignment="center"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/img_map_type_satellite"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/ll_hybrid"
            android:background="@drawable/bg_curved_surfacecontainer_16dp"
            android:padding="2dp"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/ll_satellite"
            app:layout_constraintTop_toBottomOf="@+id/lbl_choose_map">
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/img_map_type_hybrid"
                android:layout_width="0px"
                android:layout_height="0px"
                android:scaleType="centerInside"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearance="@style/ShapeAppearance.CurvedTop16DP"
                app:srcCompat="@drawable/ic_map_style_hybrid_122dp"/>
            <TextView
                android:textSize="16sp"
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:text="@string/Hybrid"
                android:maxLines="1"
                android:fontFamily="@string/font_roboto_medium"
                android:textAlignment="center"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/img_map_type_hybrid"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>

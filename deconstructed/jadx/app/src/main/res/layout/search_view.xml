<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/search_layout"
    android:visibility="invisible"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/transparent_view"
        android:background="@color/colorTransparentBlack50"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:id="@+id/search_top_bar"
            android:background="?attr/colorSurface"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">
            <EditText
                android:textSize="16sp"
                android:id="@+id/searchTextView"
                android:background="@null"
                android:paddingLeft="@dimen/search_view_text_padding"
                android:paddingRight="@dimen/search_view_text_padding"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="@string/search_hint"
                android:singleLine="true"
                android:inputType="textNoSuggestions"
                android:imeOptions="actionNone"/>
            <ImageButton
                android:id="@+id/action_up_btn"
                android:layout_centerVertical="true"
                app:srcCompat="@drawable/ic_outline_arrow_back_colortoolbartext_24dp"
                style="@style/MSV_ImageButton"/>
            <ImageButton
                android:id="@+id/action_voice_btn"
                android:layout_alignParentRight="true"
                android:layout_alignParentEnd="true"
                app:srcCompat="@drawable/ic_baseline_mic_24"
                app:tint="?attr/nand_toolbar_textColorPrimary"
                style="@style/MSV_ImageButton"/>
            <ImageButton
                android:id="@+id/action_empty_btn"
                android:visibility="gone"
                android:layout_alignParentRight="true"
                android:layout_alignParentEnd="true"
                app:srcCompat="@drawable/ic_baseline_close_colortoolbartext_24dp"
                style="@style/MSV_ImageButton"/>
            <View
                android:background="#fff"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_alignParentBottom="true"
                android:backgroundTint="#10000000"/>
        </RelativeLayout>
        <ListView
            android:id="@+id/suggestion_list"
            android:background="?attr/colorSurface"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="?attr/colorOutlineVariant"/>
    </LinearLayout>
</FrameLayout>

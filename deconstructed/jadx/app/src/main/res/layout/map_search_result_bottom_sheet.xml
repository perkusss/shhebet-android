<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/bottom_sheet"
    android:tag="layout/map_search_result_bottom_sheet_0"
    android:background="?attr/colorSurface"
    android:focusable="true"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:behavior_hideable="true"
    app:cardElevation="10dp"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.AppBarLayout
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            android:id="@+id/appbar"
            android:background="?attr/colorSurface"
            android:fitsSystemWindows="true"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:id="@+id/collapsing_toolbar"
                android:fitsSystemWindows="true"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:contentScrim="?attr/colorSurface"
                app:expandedTitleMarginStart="30dp"
                app:layout_scrollFlags="snap|exitUntilCollapsed|scroll">
                <ImageView
                    android:id="@+id/fullDetailsURLImage"
                    android:visibility="visible"
                    android:fitsSystemWindows="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:src="@drawable/combined_shape"
                    android:scaleType="centerCrop"
                    android:minHeight="200dp"
                    app:layout_collapseMode="parallax"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <com.google.android.material.appbar.MaterialToolbar
                    android:id="@+id/anim_toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_collapseMode="pin"
                    app:popupTheme="@style/Widget.App.PopupMenu.Overflow"/>
            </com.google.android.material.appbar.CollapsingToolbarLayout>
        </com.google.android.material.appbar.AppBarLayout>
        <TextView
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/fullDetailsTitle"
            android:focusableInTouchMode="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:maxWidth="170dp"
            android:minWidth="100dp"
            android:maxLines="1"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/appbar"
            style="?android:attr/textViewStyle"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="normal"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/fullDetailsDistanceInKm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="8.6 Km"
            android:fontFamily="sans-serif"
            app:layout_constraintStart_toStartOf="@+id/fullDetailsTitle"
            app:layout_constraintTop_toBottomOf="@+id/fullDetailsTitle"/>
        <TextView
            android:textSize="12sp"
            android:textStyle="normal"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:id="@+id/fullDetailsDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxWidth="170dp"
            android:minWidth="100dp"
            android:maxLines="2"
            android:fontFamily="sans-serif-light"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/fullDetailsDistanceInKm"/>
        <androidx.cardview.widget.CardView
            android:id="@+id/directions"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="16dp"
            android:foreground="?android:attr/selectableItemBackground"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="15dp"
            app:cardBackgroundColor="?attr/colorPrimary"
            app:cardCornerRadius="18dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/fullDetailsDescription">
            <ImageView
                android:layout_gravity="center"
                android:tag="binding_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:srcCompat="@drawable/ic_directions_white_24dp"/>
        </androidx.cardview.widget.CardView>
        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintBottom_toTopOf="@+id/directions"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/directions"
            app:layout_constraintTop_toBottomOf="@+id/directions">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/buttons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="0dp"
                android:paddingEnd="8dp">
                <androidx.cardview.widget.CardView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/bottomSheetChannel"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:minWidth="90dp"
                    android:layout_marginStart="16dp"
                    app:cardBackgroundColor="?attr/colorPrimary"
                    app:cardCornerRadius="17dp"
                    app:cardElevation="3dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="34dp">
                        <ImageView
                            android:id="@+id/bottomSheetChannelIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_chats_24dp"
                            app:tint="@color/colorSurfaceContainer"/>
                        <TextView
                            android:textSize="13sp"
                            android:textColor="?attr/colorSurface"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:id="@+id/bottomSheetChannelText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="2dp"
                            android:text="@string/open"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="10dp"
                            app:layout_constraintBottom_toTopOf="@+id/bottomSheetChannelIcon"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/bottomSheetChannelIcon"
                            app:layout_constraintTop_toBottomOf="@+id/bottomSheetChannelIcon"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/bottomSheetChat"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:minWidth="90dp"
                    android:layout_marginStart="16dp"
                    app:cardBackgroundColor="?attr/colorPrimary"
                    app:cardCornerRadius="17dp"
                    app:cardElevation="3dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/bottomSheetChannel"
                    app:layout_constraintTop_toTopOf="parent">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="34dp">
                        <ImageView
                            android:id="@+id/bottomSheetChatIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_chats_24dp"
                            app:tint="?attr/colorSurface"/>
                        <TextView
                            android:textSize="13sp"
                            android:textColor="?attr/colorSurface"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:id="@+id/bottomSheetChatText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="2dp"
                            android:text="@string/open"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="10dp"
                            app:layout_constraintBottom_toTopOf="@+id/bottomSheetChatIcon"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/bottomSheetChatIcon"
                            app:layout_constraintTop_toBottomOf="@+id/bottomSheetChatIcon"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/bottomSheetVAPP"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:minWidth="90dp"
                    android:layout_marginStart="16dp"
                    app:cardBackgroundColor="?attr/colorPrimary"
                    app:cardCornerRadius="17dp"
                    app:cardElevation="3dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/bottomSheetChat"
                    app:layout_constraintTop_toTopOf="parent">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="34dp">
                        <ImageView
                            android:id="@+id/bottomSheetVAPPIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_virtual_app_24dp"
                            app:tint="?attr/colorSurface"/>
                        <TextView
                            android:textSize="13sp"
                            android:textColor="?attr/colorSurface"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:id="@+id/bottomSheetVAPPText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="2dp"
                            android:text="@string/open"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="10dp"
                            app:layout_constraintBottom_toTopOf="@+id/bottomSheetVAPPIcon"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/bottomSheetVAPPIcon"
                            app:layout_constraintTop_toBottomOf="@+id/bottomSheetVAPPIcon"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/bottomSheetMStoreBtn"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="90dp"
                    android:layout_marginStart="16dp"
                    app:cardBackgroundColor="?attr/colorPrimary"
                    app:cardCornerRadius="17dp"
                    app:cardElevation="3dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/bottomSheetVAPP"
                    app:layout_constraintTop_toTopOf="parent">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="34dp">
                        <ImageView
                            android:id="@+id/bottomSheetMStoreIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_store_24dp"
                            app:tint="?attr/colorSurface"/>
                        <TextView
                            android:textSize="13sp"
                            android:textColor="?attr/colorSurface"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:id="@+id/bottomSheetMStoreText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="2dp"
                            android:text="@string/order"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="10dp"
                            app:layout_constraintBottom_toTopOf="@+id/bottomSheetMStoreIcon"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/bottomSheetMStoreIcon"
                            app:layout_constraintTop_toBottomOf="@+id/bottomSheetMStoreIcon"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/openBookingBtn"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:minWidth="90dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:cardBackgroundColor="?attr/colorPrimary"
                    app:cardCornerRadius="17dp"
                    app:cardElevation="3dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/bottomSheetMStoreBtn"
                    app:layout_constraintTop_toTopOf="parent">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="34dp">
                        <ImageView
                            android:id="@+id/bookingIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_booking_18dp"
                            app:tint="?attr/colorSurface"/>
                        <TextView
                            android:textSize="13sp"
                            android:textColor="?attr/colorSurface"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:id="@+id/bookingText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="2dp"
                            android:text="@string/book"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="10dp"
                            app:layout_constraintBottom_toTopOf="@+id/bookingIcon"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/bookingIcon"
                            app:layout_constraintTop_toBottomOf="@+id/bookingIcon"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/openEventBtn"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:minWidth="90dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:cardBackgroundColor="?attr/colorPrimary"
                    app:cardCornerRadius="17dp"
                    app:cardElevation="3dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/openBookingBtn"
                    app:layout_constraintTop_toTopOf="parent">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="34dp">
                        <ImageView
                            android:id="@+id/eventIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_event_24dp"
                            app:tint="?attr/colorSurface"/>
                        <TextView
                            android:textSize="13sp"
                            android:textColor="?attr/colorSurface"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:id="@+id/eventText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="2dp"
                            android:text="@string/event"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="10dp"
                            app:layout_constraintBottom_toTopOf="@+id/eventIcon"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/eventIcon"
                            app:layout_constraintTop_toBottomOf="@+id/eventIcon"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </HorizontalScrollView>
        <TextView
            android:textSize="13sp"
            android:textStyle="normal"
            android:textColor="#4285f4"
            android:id="@+id/directionTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="@string/directions"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintEnd_toStartOf="@+id/directions"
            app:layout_constraintStart_toEndOf="@+id/directions"
            app:layout_constraintTop_toBottomOf="@+id/directions"/>
        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/separator1"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginTop="15dp"
            app:dividerColor="?attr/colorOutlineVariant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/directionTextView"/>
        <ImageView
            android:id="@+id/addressLocationIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginStart="22dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/separator1"
            app:srcCompat="@drawable/ic_location_24_dp"/>
        <TextView
            android:textSize="13sp"
            android:textStyle="normal"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/addressLocationTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            app:layout_constraintBottom_toTopOf="@+id/addressLocationIcon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/addressLocationIcon"
            app:layout_constraintTop_toBottomOf="@+id/addressLocationIcon"/>
        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/separator2"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginTop="12dp"
            app:dividerColor="?attr/colorOutlineVariant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/addressLocationIcon"/>
        <ImageView
            android:id="@+id/urlIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginStart="22dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/separator2"
            app:srcCompat="@drawable/ic_public_24_dp"/>
        <TextView
            android:textSize="13sp"
            android:textStyle="normal"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/urlTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            app:layout_constraintBottom_toTopOf="@+id/urlIcon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/urlIcon"
            app:layout_constraintTop_toBottomOf="@+id/urlIcon"/>
        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/separator3"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginTop="12dp"
            app:dividerColor="?attr/colorOutlineVariant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/urlIcon"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>

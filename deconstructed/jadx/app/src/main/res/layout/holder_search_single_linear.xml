<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/root"
    android:background="?attr/selectableItemBackground"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <FrameLayout
            android:layout_gravity="center_vertical"
            android:id="@+id/image_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="16dp">
            <de.hdodenhof.circleimageview.CircleImageView
                android:layout_gravity="center"
                android:id="@+id/img_icon"
                android:layout_width="54dp"
                android:layout_height="54dp"
                app:srcCompat="@drawable/ic_contact_130dp"/>
        </FrameLayout>
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="18dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/img_type"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="1dp"
                    android:layout_marginEnd="8dp"
                    android:layout_alignParentStart="true"
                    app:srcCompat="@drawable/ic_bot_18dp"
                    app:tint="?attr/colorOnSurfaceVariant"/>
                <RelativeLayout
                    android:id="@+id/contact_name_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@+id/img_type">
                    <TextView
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        android:ellipsize="end"
                        android:id="@+id/txt_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Melissa Brewer"
                        android:lines="1"
                        android:singleLine="true"
                        android:textDirection="firstStrong"
                        android:layout_marginEnd="80dp"
                        android:layout_alignParentStart="true"/>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/member_count_view"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true">
                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:srcCompat="@drawable/ic_person_24dp"/>
                        <TextView
                            android:textSize="12sp"
                            android:textStyle="normal"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_gravity="center"
                            android:id="@+id/member_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@string/font_roboto"/>
                    </LinearLayout>
                </RelativeLayout>
            </RelativeLayout>
            <github.ankushsachdeva.emojicon.EmojiconTextView
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:ellipsize="end"
                android:layout_gravity="bottom"
                android:id="@+id/txt_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aw dang. I wish I could."
                android:maxLines="1"
                android:singleLine="true"
                android:textDirection="locale"/>
            <github.ankushsachdeva.emojicon.EmojiconTextView
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:ellipsize="end"
                android:layout_gravity="bottom"
                android:id="@+id/txt_description2"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aw dang. I wish I could."
                android:maxLines="1"
                android:singleLine="true"
                android:textDirection="locale"/>
        </LinearLayout>
    </LinearLayout>
    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</LinearLayout>

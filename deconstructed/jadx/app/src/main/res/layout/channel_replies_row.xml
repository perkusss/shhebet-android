<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:background="?attr/selectableItemBackground"
    android:paddingTop="10dp"
    android:paddingBottom="5dp"
    android:descendantFocusability="blocksDescendants"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:id="@+id/image_container"
        android:paddingLeft="15dp"
        android:paddingRight="15dp"
        android:layout_width="wrap_content"
        android:layout_height="match_parent">
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/contact_icon"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_width="40dp"
            android:layout_height="40dp"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_gravity="fill"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="15dp">
        <TextView
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurface"
            android:ellipsize="end"
            android:gravity="start"
            android:id="@+id/contact_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:text="Mike Cryst"
            android:lines="1"
            android:fontFamily="@string/font_roboto_medium"
            android:textDirection="firstStrong"/>
        <LinearLayout
            android:layout_gravity="fill"
            android:orientation="horizontal"
            android:id="@+id/chat_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/message_type_icon"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"/>
            <github.ankushsachdeva.emojicon.EmojiconTextView
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:ellipsize="end"
                android:layout_gravity="end|fill_vertical"
                android:id="@+id/last_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:maxLines="2"
                android:fontFamily="@string/font_roboto"
                android:textDirection="firstStrong"
                app:emojiconSize="16sp"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/message_content_icon"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="5dp"
                app:srcCompat="@drawable/ic_outline_access_time_18dp"
                app:tint="?attr/colorOnSurfaceVariant"/>
            <TextView
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center"
                android:id="@+id/message_date"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:text="10 Hours ago"
                android:fontFamily="@string/font_roboto"/>
            <TextView
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center"
                android:id="@+id/dot_view"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:text="."/>
            <TextView
                android:textSize="12sp"
                android:textColor="?attr/colorTertiary"
                android:gravity="center"
                android:id="@+id/reply_btn"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:text="@string/reply"
                android:fontFamily="@string/font_roboto_medium"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="?attr/selectableItemBackground"
    android:focusable="false"
    android:clickable="false"
    android:descendantFocusability="blocksDescendants"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <FrameLayout
            android:id="@+id/image_container"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:paddingTop="11dp"
            android:paddingBottom="11dp"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="14dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="false">
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/group_image"
                android:layout_width="54dp"
                android:layout_height="54dp"/>
            <ImageView
                android:layout_gravity="end|bottom"
                android:id="@+id/verified_icon"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                app:srcCompat="@drawable/ic_verified_green_18dp"/>
        </FrameLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/group_details_views"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@+id/invite_favorite_views"
            android:layout_toEndOf="@+id/image_container">
            <RelativeLayout
                android:id="@+id/group_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/group_type_icon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="0dp"
                    android:layout_marginEnd="8dp"
                    app:srcCompat="@drawable/ic_outline_channel_18dp"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:layout_toStartOf="@null"
                    android:layout_toEndOf="@+id/group_type_icon">
                    <TextView
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        android:ellipsize="end"
                        android:gravity="start"
                        android:id="@+id/group_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mike Cryst"
                        android:lines="1"
                        android:textDirection="firstStrong"/>
                </LinearLayout>
            </RelativeLayout>
            <RelativeLayout
                android:id="@+id/chat_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_below="@+id/profile_info">
                <github.ankushsachdeva.emojicon.EmojiconTextView
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="start"
                    android:id="@+id/quote_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="hi all"
                    android:singleLine="true"
                    android:textDirection="firstStrong"
                    android:layout_marginStart="0dp"
                    android:layout_marginEnd="4dp"
                    android:layout_toEndOf="@null"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentEnd="false"
                    app:emojiconSize="16sp"/>
            </RelativeLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/invite_favorite_views"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="16dp"
            android:layout_alignParentStart="false"
            android:layout_alignParentEnd="true">
            <TextView
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:id="@+id/group_member_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Super Admin"
                android:layout_centerHorizontal="true"/>
            <FrameLayout
                android:layout_gravity="end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_gravity="end"
                    android:id="@+id/favorite_image"
                    android:visibility="visible"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    app:srcCompat="@drawable/ic_star_yellow_18dp"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:layout_gravity="end"
                    android:id="@+id/new_text"
                    android:background="@drawable/curved_primary_container_button"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/new_text"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"/>
            </FrameLayout>
        </LinearLayout>
        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/item_divider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/image_container"
            android:layout_toStartOf="@null"
            android:layout_toEndOf="@+id/image_container"/>
    </RelativeLayout>
</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="start"
    android:id="@+id/root_view"
    android:paddingTop="@dimen/default_message_item_padding_top"
    android:paddingBottom="@dimen/default_message_item_padding_bottom"
    android:focusable="true"
    android:clickable="true"
    android:descendantFocusability="blocksDescendants"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="@drawable/message_board_selected_row">
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/profile_icon"
        android:background="?attr/selectableItemBackground"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:duplicateParentState="true"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="0dp"
        app:srcCompat="@drawable/ic_contact_130dp"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/body_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_padding_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="3dp">
                <FrameLayout
                    android:id="@+id/frm_inline_reply_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <github.ankushsachdeva.emojicon.EmojiconTextView
                    android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                    android:textSize="16sp"
                    android:ellipsize="end"
                    android:gravity="start"
                    android:layout_gravity="start"
                    android:id="@+id/profile_name"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="3dp"
                    android:lines="1"
                    android:fontFamily="@string/font_roboto"
                    android:textDirection="locale"
                    app:emojiconSize="16sp"/>
                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <FrameLayout
                        android:orientation="vertical"
                        android:id="@+id/content_view"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <androidx.cardview.widget.CardView
                                android:layout_gravity="center"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:cardCornerRadius="12dp"
                                app:cardElevation="0dp">
                                <ImageView
                                    android:layout_gravity="center"
                                    android:id="@+id/message_board_image"
                                    android:background="?attr/colorSurface"
                                    android:visibility="visible"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:scaleType="fitXY"
                                    android:minWidth="150dp"
                                    android:minHeight="150dp"/>
                            </androidx.cardview.widget.CardView>
                        </LinearLayout>
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@+id/message_board_play_icon"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:scaleType="centerCrop"
                            app:srcCompat="@drawable/ic_gif_pause_58dp"/>
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@+id/message_board_retry_icon"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:scaleType="centerCrop"
                            app:srcCompat="@drawable/ic_download_imgorvideo_black_58dp"/>
                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:layout_gravity="center"
                            android:id="@+id/spinner"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:indicatorSize="55dp"
                            app:trackColor="@android:color/transparent"
                            app:trackThickness="5dp"/>
                        <include
                            android:layout_gravity="bottom"
                            android:id="@+id/footer_view_item"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="3dp"
                            layout="@layout/message_board_footer_row_photo"/>
                    </FrameLayout>
                    <github.ankushsachdeva.emojicon.EmojiconTextView
                        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface"
                        android:textColorLink="?attr/nand_link_color"
                        android:ellipsize="end"
                        android:autoLink="web"
                        android:linksClickable="true"
                        android:id="@+id/message_board_text"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp"
                        android:minWidth="120dp"
                        android:layout_below="@+id/content_view"
                        android:fontFamily="@string/font_roboto"
                        android:layout_alignStart="@+id/content_view"
                        android:layout_alignEnd="@+id/content_view"
                        app:emojiconSize="@dimen/message_emoji_size"/>
                </RelativeLayout>
            </LinearLayout>
        </LinearLayout>
        <com.nandbox.view.util.chatMenu.ChatMenuLayout
            android:orientation="vertical"
            android:id="@+id/inline_menu_view"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"/>
    </LinearLayout>
</LinearLayout>

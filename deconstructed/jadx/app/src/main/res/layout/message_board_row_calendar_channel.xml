<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_view"
    android:background="?attr/colorSurfaceContainerLowest"
    android:paddingTop="@dimen/channel_message_item_padding_top"
    android:focusable="true"
    android:clickable="true"
    android:descendantFocusability="blocksDescendants"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/body_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center"
            android:id="@+id/header_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp">
            <include
                android:id="@+id/header_view_item"
                android:layout_width="match_parent"
                android:layout_height="@dimen/channel_header_height"
                layout="@layout/message_board_header_row_channel"/>
        </LinearLayout>
        <androidx.cardview.widget.CardView
            android:orientation="vertical"
            android:id="@+id/content_view"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minWidth="250dp"
            app:cardCornerRadius="@dimen/image_corner_Radius"
            app:cardElevation="0dp"
            app:cardUseCompatPadding="true"
            app:contentPadding="0dp">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/_8dp">
                <ImageView
                    android:layout_gravity="start|top"
                    android:visibility="visible"
                    android:layout_width="56sp"
                    android:layout_height="56sp"
                    android:scaleType="centerCrop"
                    app:srcCompat="@drawable/ic_calendar_default"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_8dp"
                        android:layout_marginEnd="@dimen/_8dp">
                        <FrameLayout
                            android:orientation="vertical"
                            android:background="?attr/colorSurface"
                            android:layout_width="19dp"
                            android:layout_height="19dp"
                            android:layout_marginEnd="5dp">
                            <de.hdodenhof.circleimageview.CircleImageView
                                android:layout_gravity="start|top"
                                android:id="@+id/message_board_image"
                                android:visibility="visible"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"/>
                            <ImageView
                                android:layout_gravity="center"
                                android:id="@+id/message_board_play_icon"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:scaleType="centerCrop"
                                app:srcCompat="@drawable/ic_gif_pause_58dp"/>
                            <ImageView
                                android:layout_gravity="center"
                                android:id="@+id/message_board_retry_icon"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:scaleType="centerCrop"
                                app:srcCompat="@drawable/ic_download_imgorvideo_black_58dp"/>
                            <com.google.android.material.progressindicator.CircularProgressIndicator
                                android:layout_gravity="center"
                                android:id="@+id/spinner"
                                android:visibility="gone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:indicatorSize="55dp"
                                app:trackColor="@android:color/transparent"
                                app:trackThickness="5dp"/>
                        </FrameLayout>
                        <github.ankushsachdeva.emojicon.EmojiconTextView
                            android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:textColorLink="?attr/nand_link_color"
                            android:ellipsize="end"
                            android:autoLink="web"
                            android:linksClickable="true"
                            android:layout_gravity="start"
                            android:id="@+id/message_board_text"
                            android:visibility="visible"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:lines="1"
                            android:fontFamily="@string/font_roboto"
                            app:emojiconSize="@dimen/message_emoji_size"/>
                    </LinearLayout>
                    <github.ankushsachdeva.emojicon.EmojiconTextView
                        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                        android:textSize="12sp"
                        android:textStyle="normal"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textColorLink="?attr/nand_link_color"
                        android:autoLink="web"
                        android:linksClickable="true"
                        android:layout_gravity="start"
                        android:id="@+id/desc_text"
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:maxLines="3"
                        android:lineSpacingExtra="6sp"
                        android:fontFamily="@string/font_roboto"
                        android:layout_marginStart="@dimen/_8dp"
                        android:layout_marginEnd="@dimen/_8dp"
                        app:emojiconSize="@dimen/message_emoji_size"/>
                    <Button
                        android:gravity="center"
                        android:layout_gravity="end|bottom"
                        android:id="@+id/accept_button"
                        android:visibility="visible"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        android:text="@string/accept"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <com.nandbox.view.util.chatMenu.ChatMenuLayout
            android:id="@+id/inline_menu_view"
            android:background="?attr/colorSurfaceContainerLow"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"/>
        <LinearLayout
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <include
                android:id="@+id/footer_view_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/message_board_footer_row_channel"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

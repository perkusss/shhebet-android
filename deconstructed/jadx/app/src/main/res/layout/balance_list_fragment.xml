<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_view"
    android:background="?attr/colorSurface"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/toolbar_container"
        android:background="?attr/nand_colorM3Surface"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/tool_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:popupTheme="@style/Widget.App.PopupMenu.Overflow"/>
            <com.nandbox.view.util.materialsearchview.MaterialSearchView
                android:textColor="@color/colorM2OnSurface"
                android:textColorHint="@color/colorM2OnSurfaceVariant"
                android:id="@+id/search_view"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:hint="@string/search_hint"
                android:layout_marginStart="4dp"
                app:searchBackIcon="@drawable/ic_outline_arrow_back_colortoolbartext_24dp"
                app:searchBackground="@color/colorM2ASurface"
                app:searchCloseIcon="@drawable/ic_close_white_24_dp"/>
        </FrameLayout>
    </com.google.android.material.appbar.AppBarLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/default_list"
        android:background="?attr/colorSurfaceContainer"
        android:paddingBottom="5dp"
        android:clipToPadding="false"
        android:layout_width="0px"
        android:layout_height="0px"
        android:choiceMode="singleChoice"
        android:splitMotionEvents="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar_container"/>
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:focusable="false"
        android:clickable="false"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/default_space"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar_container">
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_gravity="center"
            android:id="@+id/spinner"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="29dp"/>
        <ImageView
            android:layout_gravity="center_horizontal"
            android:id="@+id/img_no_items"
            android:visibility="gone"
            android:layout_width="66dp"
            android:layout_height="66dp"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="?attr/colorOnSurface"
            android:gravity="center"
            android:id="@+id/no_message_title"
            android:focusable="false"
            android:visibility="gone"
            android:clickable="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@string/font_roboto_medium"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="normal"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="center"
            android:id="@+id/no_message_desc"
            android:focusable="false"
            android:visibility="gone"
            android:clickable="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@string/font_roboto"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

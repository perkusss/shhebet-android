<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fl_root"
    android:background="?attr/selectableItemBackground"
    android:descendantFocusability="blocksDescendants"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="12dp">
        <TextView
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:id="@+id/txt_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A"
            android:fontFamily="@string/font_roboto_medium"/>
        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/group_image"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="12dp"
        android:scaleType="centerCrop"
        android:layout_below="@+id/ll_header"
        app:srcCompat="@drawable/ic_event_100dp"/>
    <RelativeLayout
        android:id="@+id/fl_details_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_marginRight="12dp"
        android:layout_marginBottom="14dp"
        android:layout_toRightOf="@+id/group_image"
        android:layout_alignTop="@+id/group_image">
        <ImageView
            android:id="@+id/img_booking"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:scaleType="center"
            app:srcCompat="@drawable/ic_booking_18dp"
            app:tint="?attr/colorOnSurfaceVariant"/>
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:ellipsize="end"
            android:id="@+id/group_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="4dp"
            android:text="Arena Munoz Wedding"
            android:maxLines="1"
            android:layout_toRightOf="@+id/img_booking"
            android:fontFamily="@string/font_roboto"
            android:textDirection="locale"/>
        <ImageView
            android:id="@+id/img_group_description"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginTop="7dp"
            android:scaleType="center"
            android:layout_below="@+id/group_name"
            app:srcCompat="@drawable/ic_day_18dp"
            app:tint="?attr/colorOnSurfaceVariant"/>
        <TextView
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:ellipsize="end"
            android:id="@+id/txt_group_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4dp"
            android:layout_marginTop="7dp"
            android:text="Apply online now from anywhere"
            android:maxLines="2"
            android:layout_toRightOf="@+id/img_group_description"
            android:layout_below="@+id/group_name"
            android:fontFamily="@string/font_roboto"
            android:textDirection="locale"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/img_location"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginTop="7dp"
            android:layout_below="@+id/txt_group_description"
            app:srcCompat="@drawable/ic_location_18dp"
            app:tint="?attr/colorOnSurfaceVariant"/>
        <TextView
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:ellipsize="end"
            android:layout_gravity="center_vertical"
            android:id="@+id/txt_group_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4dp"
            android:layout_marginTop="7dp"
            android:layout_marginRight="12dp"
            android:text="90th N and 90th S intersection…"
            android:maxLines="2"
            android:layout_toRightOf="@+id/img_location"
            android:layout_below="@+id/txt_group_description"
            android:fontFamily="@string/font_roboto"
            android:textDirection="locale"/>
    </RelativeLayout>
    <com.google.android.material.divider.MaterialDivider
        android:id="@+id/item_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_alignLeft="@+id/fl_details_container"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"
        app:dividerColor="?attr/colorOutlineVariant"/>
</RelativeLayout>

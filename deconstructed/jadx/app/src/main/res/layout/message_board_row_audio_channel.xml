<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_view"
    android:background="?attr/colorSurfaceContainerLowest"
    android:paddingTop="@dimen/channel_message_item_padding_top"
    android:focusable="true"
    android:clickable="true"
    android:descendantFocusability="blocksDescendants"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/body_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center"
            android:id="@+id/header_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp">
            <include
                android:id="@+id/header_view_item"
                android:layout_width="match_parent"
                android:layout_height="@dimen/channel_header_height"
                layout="@layout/message_board_header_row_channel"/>
        </LinearLayout>
        <github.ankushsachdeva.emojicon.EmojiconTextView
            android:textAppearance="@style/TextAppearance.AppCompat.Body1"
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurface"
            android:textColorLink="?attr/nand_link_color"
            android:autoLink="web"
            android:linksClickable="true"
            android:layout_gravity="start"
            android:id="@+id/message_board_text"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"
            android:fontFamily="@string/font_roboto"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            app:emojiconSize="24sp"/>
        <FrameLayout
            android:orientation="vertical"
            android:id="@+id/content_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/bg_soundmessages_timer"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_gravity="center_horizontal"
                        android:id="@+id/img_audio_icon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginTop="8dp"
                        app:srcCompat="@drawable/ic_headset_white_24_dp"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnTertiary"
                        android:gravity="center"
                        android:layout_gravity="center_horizontal"
                        android:id="@+id/progress_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="4:56"/>
                </LinearLayout>
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <TextView
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:gravity="center"
                        android:id="@+id/audio_name"
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:singleLine="true"
                        android:layout_above="@+id/seek_bar"
                        android:layout_alignParentTop="true"
                        android:fontFamily="@string/font_roboto"
                        android:layout_marginStart="13dp"
                        android:layout_marginEnd="0dp"
                        android:layout_toStartOf="@null"
                        android:layout_toEndOf="@+id/control_frame"/>
                    <SeekBar
                        android:id="@+id/seek_bar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:progress="0"
                        android:thumbOffset="1dp"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@null"
                        android:layout_toEndOf="@+id/control_frame"
                        style="@style/SeekbarCustomProgressBarHorizontal"/>
                    <RelativeLayout
                        android:id="@+id/control_frame"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentEnd="false">
                        <ImageView
                            android:id="@+id/play_button"
                            android:visibility="visible"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/play"
                            android:layout_centerVertical="true"
                            app:srcCompat="@drawable/ic_play_arrow_black_36dp"/>
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@+id/pause_button"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pause"
                            android:layout_centerVertical="true"
                            app:srcCompat="@drawable/ic_pause_black_36dp"/>
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@+id/cancel_button"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pause"
                            android:layout_centerVertical="true"
                            app:srcCompat="@drawable/ic_close_black_36dp"
                            app:tint="?attr/colorOnSurfaceVariant"/>
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@+id/retry_button"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Retry"
                            android:layout_centerVertical="true"
                            app:srcCompat="@drawable/ic_download_imgorvideo_black_58dp"/>
                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:layout_gravity="center"
                            android:id="@+id/spinner"
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:indicatorSize="28dp"
                            app:trackColor="@android:color/transparent"
                            app:trackThickness="2dp"/>
                    </RelativeLayout>
                    <TextView
                        android:textSize="@dimen/chat_time_text_size"
                        android:textStyle="normal"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:gravity="bottom"
                        android:id="@+id/audio_size"
                        android:visibility="visible"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00.0k"
                        android:singleLine="true"
                        android:maxLength="20"
                        android:layout_below="@+id/seek_bar"
                        android:layout_alignParentBottom="true"
                        android:fontFamily="@string/font_roboto"
                        android:layout_marginStart="@dimen/default_space"
                        android:layout_marginEnd="0dp"
                        android:layout_toStartOf="@null"
                        android:layout_toEndOf="@+id/control_frame"/>
                </RelativeLayout>
            </LinearLayout>
        </FrameLayout>
        <com.nandbox.view.util.chatMenu.ChatMenuLayout
            android:id="@+id/inline_menu_view"
            android:background="?attr/colorSurfaceContainerLow"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"/>
        <LinearLayout
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <include
                android:id="@+id/footer_view_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                layout="@layout/message_board_footer_row_channel"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

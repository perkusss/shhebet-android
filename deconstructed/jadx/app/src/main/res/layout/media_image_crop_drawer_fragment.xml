<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/layout_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_weight="100">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="12">
        <ImageView
            android:id="@+id/draw_btn"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_media_edit_24dp"
            app:tint="@android:color/white"/>
        <TextView
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:id="@+id/done_draw_text"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/done"
            android:fontFamily="@string/font_roboto"
            android:layout_marginStart="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <FrameLayout
            android:id="@+id/brush_colors_btn"
            android:background="@drawable/ic_brush_color_24dp"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.google.android.material.card.MaterialCardView
                android:layout_gravity="center"
                android:id="@+id/brush_color_view"
                android:layout_width="20dp"
                android:layout_height="20dp"
                app:cardBackgroundColor="#33f62d"
                app:cardElevation="0dp"
                app:shapeAppearance="@style/ShapeAppearance.Circle"
                app:strokeColor="@android:color/black"
                app:strokeWidth="2dp"/>
        </FrameLayout>
        <ImageView
            android:id="@+id/undo_draw_btn"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/brush_colors_btn"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_undo_24dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="4dp"
        android:layout_marginRight="4dp"
        android:layout_weight="100"
        android:layout_marginHorizontal="4dp">
        <com.isseiaoki.simplecropview.CropImageView
            android:id="@+id/crop_rotate_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:scv_crop_enabled="true"
            app:scv_crop_mode="free"
            app:scv_frame_color="@android:color/white"
            app:scv_frame_stroke_weight="1dp"
            app:scv_guide_color="@android:color/white"
            app:scv_guide_show_mode="show_always"
            app:scv_guide_stroke_weight="1px"
            app:scv_handle_color="@android:color/white"
            app:scv_handle_show_mode="show_always"
            app:scv_handle_size="4dp"
            app:scv_initial_frame_scale="1"
            app:scv_overlay_color="@color/colorTransparentBlack66"
            app:scv_touch_padding="16dp"/>
        <com.nandbox.view.util.FingerPaintImageView
            android:id="@+id/draw_image"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:inEditMode="true"/>
    </FrameLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/crop_rotate_drawer_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="22">
        <TextView
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:id="@+id/cancel_crop_rotate_text"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:fontFamily="@string/font_roboto"
            app:layout_constraintBottom_toBottomOf="@+id/rotate_btn"
            app:layout_constraintEnd_toStartOf="@+id/rotate_btn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/rotate_btn"/>
        <ImageView
            android:id="@+id/rotate_btn"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_rotate_90_24dp"/>
        <TextView
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:id="@+id/done_crop_rotate_text"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/done"
            android:fontFamily="@string/font_roboto"
            app:layout_constraintBottom_toBottomOf="@+id/rotate_btn"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/rotate_btn"
            app:layout_constraintTop_toTopOf="@+id/rotate_btn"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/brush_drawer_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="22">
        <com.google.android.material.card.MaterialCardView
            android:layout_gravity="center"
            android:id="@+id/brush_small_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#262626"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/brush_medium_view"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearance="@style/ShapeAppearance.Circle">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:srcCompat="@drawable/ic_brush_small_24dp"/>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView
            android:layout_gravity="center"
            android:id="@+id/brush_medium_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/brush_large_view"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/brush_small_view"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearance="@style/ShapeAppearance.Circle">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:srcCompat="@drawable/ic_brush_medium_24dp"/>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView
            android:layout_gravity="center"
            android:id="@+id/brush_large_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/brush_medium_view"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearance="@style/ShapeAppearance.Circle">
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:srcCompat="@drawable/ic_brush_large_24dp"/>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>

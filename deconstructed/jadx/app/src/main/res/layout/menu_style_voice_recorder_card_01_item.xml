<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginRight="4dp"
        android:layout_marginBottom="4dp"
        android:layout_marginHorizontal="4dp"
        android:layout_marginVertical="4dp"
        app:contentPadding="0dp"
        app:layout_constraintBottom_toTopOf="@+id/error_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/image_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_gravity="center"
            android:orientation="vertical"
            android:id="@+id/main_view"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/content_image"
                android:visibility="visible"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_voice_48dp"/>
            <TextView
                android:textSize="16sp"
                android:textStyle="normal"
                android:textColor="?attr/colorOnSurface"
                android:ellipsize="end"
                android:gravity="start"
                android:layout_gravity="center"
                android:id="@+id/title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:lines="1"
                android:fontFamily="@string/font_roboto_medium"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintBottom_toTopOf="@+id/desc"
                app:layout_constraintEnd_toStartOf="@+id/frameLayout3"
                app:layout_constraintStart_toEndOf="@+id/content_image"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed"
                app:layout_goneMarginStart="16dp"/>
            <TextView
                android:textSize="16sp"
                android:textStyle="normal"
                android:textColor="?attr/colorOnSurface"
                android:ellipsize="end"
                android:gravity="start"
                android:layout_gravity="center"
                android:id="@+id/desc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:lines="1"
                android:fontFamily="@string/font_roboto_medium"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/frameLayout3"
                app:layout_constraintStart_toEndOf="@+id/content_image"
                app:layout_constraintTop_toBottomOf="@+id/title"
                app:layout_goneMarginStart="16dp"/>
            <FrameLayout
                android:id="@+id/frameLayout3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <com.google.android.material.button.MaterialButton
                    android:ellipsize="end"
                    android:id="@+id/select_button"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:lines="1"
                    app:icon="@drawable/ic_mic_24dp"
                    app:iconTint="@android:color/white"
                    style="@style/Widget.Material3.Button.IconButton.Filled"/>
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_gravity="center"
                    android:id="@+id/progress"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:max="100"
                    app:indicatorColor="@android:color/white"
                    app:indicatorSize="36dp"
                    app:trackColor="@android:color/transparent"
                    app:trackThickness="2dp"/>
            </FrameLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <TextView
            android:textSize="12sp"
            android:textColor="?attr/colorOnError"
            android:gravity="center"
            android:layout_gravity="end|top"
            android:id="@+id/unread_count_text"
            android:background="@drawable/circle_red_bg"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="6dp"
            android:minWidth="25dp"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:elevation="1dp"
            app:layout_constraintEnd_toEndOf="@+id/main_view"
            app:layout_constraintTop_toTopOf="@+id/main_view"/>
    </com.google.android.material.card.MaterialCardView>
    <TextView
        android:textSize="16sp"
        android:textStyle="normal"
        android:textColor="?attr/colorError"
        android:gravity="start"
        android:id="@+id/error_text"
        android:visibility="visible"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:lines="1"
        android:fontFamily="@string/font_roboto"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/card_view"
        app:layout_constraintStart_toStartOf="@+id/card_view"/>
</androidx.constraintlayout.widget.ConstraintLayout>

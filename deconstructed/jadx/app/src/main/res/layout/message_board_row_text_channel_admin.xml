<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="start"
    android:orientation="horizontal"
    android:id="@+id/root_view"
    android:paddingTop="@dimen/channel_reply_message_item_padding_top"
    android:paddingBottom="@dimen/channel_reply_message_item_padding_bottom"
    android:focusable="true"
    android:clickable="true"
    android:descendantFocusability="blocksDescendants"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:foreground="@drawable/message_board_selected_row">
    <de.hdodenhof.circleimageview.CircleImageView
        android:layout_gravity="start"
        android:id="@+id/profile_icon"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:duplicateParentState="true"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="@dimen/channel_admin_chat_space"
        android:layout_marginEnd="@dimen/channel_admin_chat_space"
        app:srcCompat="@drawable/ic_contact_130dp"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/body_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/content_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="120dp">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/content_sub_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/header_name_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <github.ankushsachdeva.emojicon.EmojiconTextView
                        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface"
                        android:ellipsize="end"
                        android:gravity="start"
                        android:layout_gravity="start"
                        android:id="@+id/group_name"
                        android:visibility="visible"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="3dp"
                        android:text="@string/app_name"
                        android:lines="1"
                        android:fontFamily="@string/font_roboto_medium"
                        app:emojiconSize="16sp"/>
                    <TextView
                        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                        android:textSize="16sp"
                        android:ellipsize="end"
                        android:gravity="start"
                        android:layout_gravity="start"
                        android:id="@+id/dot_view"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="3dp"
                        android:text="."
                        android:lines="1"
                        android:fontFamily="@string/font_roboto"
                        android:layout_marginStart="5dp"
                        android:layout_marginEnd="5dp"/>
                    <github.ankushsachdeva.emojicon.EmojiconTextView
                        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:ellipsize="end"
                        android:gravity="start"
                        android:layout_gravity="start"
                        android:id="@+id/profile_name"
                        android:visibility="visible"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="3dp"
                        android:text="@string/app_name"
                        android:lines="1"
                        android:fontFamily="@string/font_roboto"
                        app:emojiconSize="14sp"/>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/message_board_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <github.ankushsachdeva.emojicon.EmojiconTextView
                        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textColorLink="?attr/nand_link_color"
                        android:autoLink="none"
                        android:linksClickable="true"
                        android:id="@+id/message_board_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp"
                        android:text="@string/app_name"
                        android:fontFamily="@string/font_roboto"
                        android:textDirection="firstStrong"
                        app:emojiconSize="@dimen/message_emoji_size"/>
                </LinearLayout>
                <androidx.cardview.widget.CardView
                    android:layout_gravity="center"
                    android:id="@+id/big_message_board_view"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="100dp"
                    app:cardCornerRadius="0dp"
                    app:cardElevation="0dp">
                    <github.ankushsachdeva.emojicon.EmojiconTextView
                        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                        android:textSize="22sp"
                        android:textColor="@color/colorBigText"
                        android:textColorLink="@color/colorBigText"
                        android:gravity="center"
                        android:autoLink="none"
                        android:linksClickable="true"
                        android:layout_gravity="center"
                        android:id="@+id/big_message_board_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="15dp"
                        android:text="@string/app_name"
                        android:fontFamily="@string/font_roboto_medium"
                        app:emojiconSize="@dimen/message_emoji_size"/>
                </androidx.cardview.widget.CardView>
                <TextView
                    android:textSize="16sp"
                    android:textColor="?attr/nand_link_color"
                    android:id="@+id/read_more_btn"
                    android:background="?attr/selectableItemBackground"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/read_more"
                    android:fontFamily="@string/font_roboto_medium"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:id="@+id/url_view"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp">
                <include
                    android:id="@+id/url_view_item"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    layout="@layout/url_text_view"/>
            </LinearLayout>
        </LinearLayout>
        <include
            android:id="@+id/footer_view_item"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            layout="@layout/message_board_footer_row_channel_admin"/>
        <com.nandbox.view.util.chatMenu.ChatMenuLayout
            android:orientation="vertical"
            android:id="@+id/inline_menu_view"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"/>
        <com.google.android.material.divider.MaterialDivider
            android:layout_gravity="start"
            android:id="@+id/line_separator"
            android:background="?attr/colorOutlineVariant"
            android:layout_width="@dimen/channel_reply_message_item_line_separator_width"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_below="@+id/footer_view_item"/>
    </LinearLayout>
</LinearLayout>

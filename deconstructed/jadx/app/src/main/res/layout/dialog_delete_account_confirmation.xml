<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="21sp"
        android:textColor="?attr/colorOnSurface"
        android:id="@+id/txt_title"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/delete_my_account"
        android:fontFamily="@string/font_roboto_medium"
        android:textAlignment="viewStart"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:id="@+id/txt_message"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/delete_account_confirmation"
        android:fontFamily="@string/font_roboto"
        android:textAlignment="viewStart"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:lineHeight="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_title"/>
    <TextView
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:id="@+id/txt_message_acknowledge"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/please_acknowledge_by_typing"
        android:fontFamily="@string/font_roboto"
        android:textAlignment="viewStart"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:lineHeight="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_message"/>
    <EditText
        android:textSize="16sp"
        android:id="@+id/txt_type_acknowledge"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:hint="@string/type_here"
        android:maxLines="1"
        android:lines="1"
        android:inputType="number"
        android:fontFamily="@string/font_roboto"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_message_acknowledge"/>
    <Button
        android:enabled="false"
        android:textSize="14sp"
        android:textColor="@drawable/red_button_text_selector"
        android:id="@+id/btn_delete"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:layout_marginBottom="16dp"
        android:text="@string/delete"
        android:layout_marginEnd="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_type_acknowledge"
        style="@style/Widget.Material3.Button.TextButton"/>
    <com.google.android.material.button.MaterialButton
        android:textSize="14sp"
        android:id="@+id/btn_cancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:layout_marginBottom="16dp"
        android:text="@string/cancel"
        android:layout_marginEnd="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btn_delete"
        app:layout_constraintTop_toBottomOf="@+id/txt_type_acknowledge"
        style="@style/Widget.Material3.Button.TextButton"/>
</androidx.constraintlayout.widget.ConstraintLayout>

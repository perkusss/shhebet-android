<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:background="?attr/selectableItemBackground"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:id="@+id/view_icon"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="@dimen/default_space"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/icon"
            android:layout_width="54dp"
            android:layout_height="54dp"
            app:srcCompat="@drawable/ic_contact_130dp"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_toStartOf="@+id/group_member_type_invite_view"
        android:layout_toEndOf="@+id/view_icon">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/type_icon"
                android:visibility="gone"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="8dp"
                app:srcCompat="@drawable/ic_bot_18dp"
                app:tint="?attr/colorOnSurfaceVariant"/>
            <TextView
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"
                android:id="@+id/text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:fontFamily="@string/font_roboto"/>
        </LinearLayout>
        <github.ankushsachdeva.emojicon.EmojiconTextView
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:id="@+id/qoute"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:singleLine="true"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="4dp"/>
    </LinearLayout>
    <RelativeLayout
        android:gravity="center"
        android:id="@+id/group_member_type_invite_view"
        android:padding="@dimen/small_space"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="@dimen/default_space"
        android:layout_alignParentStart="false"
        android:layout_alignParentEnd="true">
        <TextView
            android:textSize="14sp"
            android:textColor="?attr/colorPrimary"
            android:id="@+id/group_member_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:fontFamily="@string/font_roboto"/>
    </RelativeLayout>
    <com.google.android.material.divider.MaterialDivider
        android:id="@+id/item_divider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/view_icon"
        android:layout_toEndOf="@+id/view_icon"
        app:dividerColor="?attr/colorOutlineVariant"/>
</RelativeLayout>

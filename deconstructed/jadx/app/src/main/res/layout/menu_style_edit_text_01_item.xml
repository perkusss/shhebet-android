<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:clickable="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="4dp"
    app:cardElevation="0dp"
    app:contentPadding="0dp">
    <FrameLayout
        android:layout_gravity="center"
        android:id="@+id/main_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.textfield.TextInputLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/title_text_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxBackgroundMode="outline"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:textSize="16sp"
                android:textStyle="normal"
                android:id="@+id/title_text_input_edit_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:imeOptions="actionDone"
                android:fontFamily="@string/font_roboto"/>
        </com.google.android.material.textfield.TextInputLayout>
    </FrameLayout>
    <TextView
        android:textSize="12sp"
        android:textColor="?attr/colorOnError"
        android:gravity="center"
        android:layout_gravity="end|top"
        android:id="@+id/unread_count_text"
        android:background="@drawable/circle_red_bg"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="6dp"
        android:minWidth="25dp"
        android:fontFamily="sans-serif-medium"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"/>
</androidx.cardview.widget.CardView>

<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:background="@drawable/bg_inline_reply_outgoing_bg"
    app:cardElevation="0dp">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <View
            android:id="@+id/v_inline_reply_left"
            android:background="@color/colorMOnPrimaryContainer"
            android:layout_width="3dp"
            android:layout_height="match_parent"/>
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <github.ankushsachdeva.emojicon.EmojiconTextView
                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:ellipsize="end"
                android:gravity="start"
                android:id="@+id/txt_reply_profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Someone"
                android:lines="1"
                android:layout_alignParentTop="true"
                android:fontFamily="@string/font_roboto"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="4dp"
                app:emojiconSize="14sp"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/txt_reply_profile_name"
                android:layout_alignStart="@+id/txt_reply_profile_name">
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/img_reply_ico"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"
                    android:layout_marginEnd="4dp"
                    app:srcCompat="@drawable/ic_photo_colorsecondarytext_16dp"/>
                <github.ankushsachdeva.emojicon.EmojiconTextView
                    android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:ellipsize="end"
                    android:gravity="start"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/txt_reply_msg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"
                    android:text="Caption"
                    android:maxLines="2"
                    android:layout_below="@+id/txt_reply_profile_name"
                    android:fontFamily="@string/font_roboto"
                    android:textDirection="firstStrong"
                    android:layout_marginEnd="4dp"
                    app:emojiconSize="14sp"/>
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>

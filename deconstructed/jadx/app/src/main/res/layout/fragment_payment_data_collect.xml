<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="?attr/colorSurfaceContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/fl_buy_container">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.cardview.widget.CardView
                android:id="@+id/crd_billing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:elevation="0dp"
                app:cardBackgroundColor="?attr/colorSurface">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/img_address"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginStart="16dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:srcCompat="@drawable/ic_location_filled_24dp"
                        app:tint="?attr/colorOnSurfaceVariant"/>
                    <TextView
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface"
                        android:id="@+id/lbl_billing_address"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/billing_address"
                        android:fontFamily="@string/font_roboto_medium"
                        android:layout_marginStart="12dp"
                        app:layout_constraintBottom_toBottomOf="@+id/img_address"
                        app:layout_constraintStart_toEndOf="@+id/img_address"
                        app:layout_constraintTop_toTopOf="@+id/img_address"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:id="@+id/txt_billing_address"
                        android:layout_width="0px"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="14dp"
                        android:text="@string/no_address_set"
                        android:fontFamily="@string/font_roboto_medium"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="8dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/txt_set_address"
                        app:layout_constraintStart_toEndOf="@+id/img_address"
                        app:layout_constraintTop_toBottomOf="@+id/lbl_billing_address"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/store_inc_dec_bg_color"
                        android:id="@+id/txt_set_address"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="14dp"
                        android:text="@string/set_address"
                        android:fontFamily="@string/font_roboto_medium"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="20dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/lbl_billing_address"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/crd_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:elevation="0dp"
                app:cardBackgroundColor="?attr/colorSurface">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cns_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="18sp"
                        android:textColor="?attr/colorOnSurface"
                        android:id="@+id/lbl_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/payment_summary"
                        android:fontFamily="@string/font_roboto_medium"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cns_details"
                        android:layout_width="0px"
                        android:layout_height="wrap_content"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/lbl_summary">
                        <TextView
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:id="@+id/lbl_sub_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="22dp"
                            android:text="@string/sub_total"
                            android:fontFamily="@string/font_roboto"
                            android:layout_marginStart="16dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <TextView
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:id="@+id/txt_sub_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@string/font_roboto"
                            android:layout_marginEnd="20dp"
                            app:layout_constraintBottom_toBottomOf="@+id/lbl_sub_total"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/lbl_sub_total"/>
                        <TextView
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:id="@+id/lbl_delivery_fee"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/delivery_fee"
                            android:fontFamily="@string/font_roboto"
                            android:layout_marginStart="16dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/lbl_sub_total"/>
                        <TextView
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:id="@+id/txt_delivery_fee"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@string/font_roboto"
                            android:layout_marginEnd="20dp"
                            app:layout_constraintBottom_toBottomOf="@+id/lbl_delivery_fee"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/lbl_delivery_fee"/>
                        <TextView
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:id="@+id/lbl_service_fee"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/serviceFee_title"
                            android:fontFamily="@string/font_roboto"
                            android:layout_marginStart="16dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/lbl_delivery_fee"/>
                        <TextView
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:id="@+id/txt_service_fee"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@string/font_roboto"
                            android:layout_marginEnd="20dp"
                            app:layout_constraintBottom_toBottomOf="@+id/lbl_service_fee"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/lbl_service_fee"/>
                        <TextView
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:id="@+id/lbl_tax"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/tax_title"
                            android:fontFamily="@string/font_roboto"
                            android:layout_marginStart="16dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/lbl_service_fee"
                            app:layout_goneMarginTop="12dp"/>
                        <TextView
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:id="@+id/txt_tax"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@string/font_roboto"
                            android:layout_marginEnd="20dp"
                            app:layout_constraintBottom_toBottomOf="@+id/lbl_tax"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/lbl_tax"/>
                        <com.google.android.material.divider.MaterialDivider
                            android:id="@+id/v_separator"
                            android:layout_width="0px"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="28dp"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"
                            app:dividerColor="?attr/colorOutlineVariant"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/lbl_tax"/>
                        <TextView
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:id="@+id/lbl_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="20dp"
                            android:text="@string/total"
                            android:fontFamily="@string/font_roboto_medium"
                            android:layout_marginStart="16dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/v_separator"/>
                        <TextView
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:id="@+id/txt_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@string/font_roboto_medium"
                            android:layout_marginEnd="20dp"
                            app:layout_constraintBottom_toBottomOf="@+id/lbl_total"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/lbl_total"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
    <FrameLayout
        android:id="@+id/fl_buy_container"
        android:background="?attr/colorSurface"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <Button
            android:layout_gravity="center"
            android:id="@+id/btn_confirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:layout_marginTop="8dp"
            android:layout_marginRight="12dp"
            android:layout_marginBottom="8dp"
            android:text="@string/confirm"/>
    </FrameLayout>
</RelativeLayout>

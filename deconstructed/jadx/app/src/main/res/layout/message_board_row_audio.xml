<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="start"
    android:id="@+id/root_view"
    android:paddingTop="@dimen/default_message_item_padding_top"
    android:paddingBottom="@dimen/default_message_item_padding_bottom"
    android:descendantFocusability="blocksDescendants"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:foreground="@drawable/message_board_selected_row">
    <de.hdodenhof.circleimageview.CircleImageView
        android:layout_gravity="start"
        android:id="@+id/profile_icon"
        android:background="?attr/selectableItemBackground"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:duplicateParentState="true"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="0dp"
        app:srcCompat="@drawable/ic_contact_130dp"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/body_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_padding_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="6dp">
                <github.ankushsachdeva.emojicon.EmojiconTextView
                    android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                    android:textSize="16sp"
                    android:ellipsize="end"
                    android:gravity="start"
                    android:layout_gravity="start"
                    android:id="@+id/profile_name"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="3dp"
                    android:lines="1"
                    android:fontFamily="@string/font_roboto"
                    app:emojiconSize="16sp"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/content_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <FrameLayout
                        android:id="@+id/frm_inline_reply_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:orientation="vertical"
                            android:background="@drawable/bg_soundmessages_timer"
                            android:layout_width="50dp"
                            android:layout_height="match_parent">
                            <ImageView
                                android:layout_gravity="center_horizontal"
                                android:id="@+id/img_audio_icon"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginTop="8dp"
                                app:srcCompat="@drawable/ic_headset_white_24_dp"/>
                            <TextView
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnTertiary"
                                android:gravity="center"
                                android:layout_gravity="center_horizontal"
                                android:id="@+id/progress_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="4dp"
                                android:text="4:56"/>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layoutDirection="ltr">
                            <FrameLayout
                                android:layout_gravity="center"
                                android:id="@+id/control_frame"
                                android:layout_width="36dp"
                                android:layout_height="36dp">
                                <ImageView
                                    android:layout_gravity="center"
                                    android:id="@+id/play_button"
                                    android:visibility="visible"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:text="@string/play"
                                    app:srcCompat="@drawable/ic_play_arrow_black_36dp"/>
                                <ImageView
                                    android:layout_gravity="center"
                                    android:id="@+id/pause_button"
                                    android:visibility="gone"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:text="@string/pause"
                                    app:srcCompat="@drawable/ic_pause_black_36dp"/>
                                <ImageView
                                    android:layout_gravity="center"
                                    android:id="@+id/cancel_button"
                                    android:visibility="gone"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:text="@string/pause"
                                    app:srcCompat="@drawable/ic_close_black_36dp"
                                    app:tint="?attr/colorOnSurfaceVariant"/>
                                <ImageView
                                    android:layout_gravity="center"
                                    android:id="@+id/retry_button"
                                    android:visibility="gone"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:text="Retry"
                                    app:srcCompat="@drawable/ic_download_imgorvideo_black_58dp"/>
                                <com.google.android.material.progressindicator.CircularProgressIndicator
                                    android:layout_gravity="center"
                                    android:id="@+id/spinner"
                                    android:visibility="gone"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    app:indicatorSize="28dp"
                                    app:trackColor="@android:color/transparent"
                                    app:trackThickness="2dp"/>
                            </FrameLayout>
                            <FrameLayout
                                android:layout_gravity="center"
                                android:orientation="vertical"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">
                                <TextView
                                    android:textSize="14sp"
                                    android:textColor="?attr/colorOnSurface"
                                    android:gravity="start|center_vertical"
                                    android:layout_gravity="top"
                                    android:id="@+id/audio_name"
                                    android:visibility="visible"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/app_name"
                                    android:singleLine="true"
                                    android:fontFamily="@string/font_roboto"
                                    android:layout_marginStart="13dp"
                                    android:layout_marginEnd="0dp"/>
                                <SeekBar
                                    android:layout_gravity="center"
                                    android:id="@+id/seek_bar"
                                    android:paddingTop="5dp"
                                    android:paddingBottom="5dp"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:progress="0"
                                    android:thumbOffset="1dp"
                                    style="@style/SeekbarCustomProgressBarHorizontal"/>
                                <LinearLayout
                                    android:layout_gravity="bottom"
                                    android:focusableInTouchMode="true"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/default_space"
                                    android:layout_marginEnd="0dp">
                                    <TextView
                                        android:textSize="@dimen/chat_time_text_size"
                                        android:textStyle="normal"
                                        android:textColor="?attr/colorOnSurfaceVariant"
                                        android:gravity="center"
                                        android:id="@+id/audio_size"
                                        android:focusableInTouchMode="false"
                                        android:visibility="visible"
                                        android:layout_width="wrap_content"
                                        android:layout_height="match_parent"
                                        android:text="00.0k"
                                        android:singleLine="true"
                                        android:fontFamily="@string/font_roboto"/>
                                    <include
                                        android:id="@+id/footer_view_item"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        layout="@layout/message_board_footer_row_normal"/>
                                </LinearLayout>
                            </FrameLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
                <github.ankushsachdeva.emojicon.EmojiconTextView
                    android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorLink="?attr/nand_link_color"
                    android:autoLink="web"
                    android:linksClickable="true"
                    android:layout_gravity="start"
                    android:id="@+id/message_board_text"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@string/font_roboto"
                    app:emojiconSize="24sp"/>
            </LinearLayout>
        </LinearLayout>
        <com.nandbox.view.util.chatMenu.ChatMenuLayout
            android:orientation="vertical"
            android:id="@+id/inline_menu_view"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"/>
    </LinearLayout>
</LinearLayout>

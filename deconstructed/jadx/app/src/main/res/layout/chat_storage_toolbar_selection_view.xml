<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="18sp"
        android:textColor="?attr/nand_toolbar_textColorPrimary"
        android:id="@+id/txt_selection_count"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:text="4 Selected"
        android:fontFamily="@string/font_roboto_medium"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="14sp"
        android:textColor="?attr/nand_toolbar_textColorSecondary"
        android:id="@+id/txt_selection_size"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        android:text="235.2 MB"
        android:fontFamily="@string/font_roboto"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_selection_count"/>
</androidx.constraintlayout.widget.ConstraintLayout>

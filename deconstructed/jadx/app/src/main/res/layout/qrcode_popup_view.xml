<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="8dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="21sp"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="@string/qr_code"
            android:fontFamily="@string/font_roboto_medium"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:id="@+id/desc_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/scan_bot_qrcode"
            android:fontFamily="@string/font_roboto"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/title_text"/>
        <androidx.cardview.widget.CardView
            android:layout_gravity="center"
            android:id="@+id/qr_code_view"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="?attr/colorSurfaceInverse"
            app:cardCornerRadius="4dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toTopOf="@+id/share_view"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/desc_text">
            <androidx.cardview.widget.CardView
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                app:cardBackgroundColor="#ffffff"
                app:cardCornerRadius="4dp"
                app:cardElevation="0dp"
                app:contentPadding="2dp">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/qr_code_image"
                    android:layout_width="@dimen/invite_link_qr_width"
                    android:layout_height="@dimen/invite_link_qr_width"/>
            </androidx.cardview.widget.CardView>
        </androidx.cardview.widget.CardView>
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/over_qr_code_image"
            android:layout_width="@dimen/invite_link_qr_inside_width"
            android:layout_height="@dimen/invite_link_qr_inside_width"
            app:civ_border_color="#ffffff"
            app:civ_border_width="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/qr_code_view"
            app:layout_constraintEnd_toEndOf="@+id/qr_code_view"
            app:layout_constraintStart_toStartOf="@+id/qr_code_view"
            app:layout_constraintTop_toTopOf="@+id/qr_code_view"/>
        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/view22"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toTopOf="@+id/share_view"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/view23"
            android:layout_width="1dp"
            android:layout_height="40dp"
            app:dividerColor="?attr/colorOutlineVariant"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/view22"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/share_view"
            android:background="?attr/selectableItemBackground"
            android:layout_width="0dp"
            android:layout_height="64dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/view23"
            app:layout_constraintStart_toStartOf="parent">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginBottom="6dp"
                app:srcCompat="@drawable/ic_share_24dp"
                app:tint="?attr/colorOnSurfaceVariant"/>
            <TextView
                android:textSize="12sp"
                android:textStyle="normal"
                android:textColor="?attr/colorOnSurface"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/share"
                android:fontFamily="@string/font_roboto"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/save_view"
            android:background="?attr/selectableItemBackground"
            android:layout_width="0dp"
            android:layout_height="64dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/view23">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginBottom="6dp"
                app:srcCompat="@drawable/ic_download_24dp"
                app:tint="?attr/colorOnSurfaceVariant"/>
            <TextView
                android:textSize="12sp"
                android:textStyle="normal"
                android:textColor="?attr/colorOnSurface"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/save"
                android:fontFamily="@string/font_roboto"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>

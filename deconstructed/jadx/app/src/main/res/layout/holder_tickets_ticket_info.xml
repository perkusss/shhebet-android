<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="24dp"
    app:cardUseCompatPadding="true">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/img_product"
            android:background="?attr/colorSurfaceContainerLowest"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:layout_marginStart="18dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_goneMarginTop="18dp"
            app:shapeAppearance="@style/ShapeAppearance.Curved8DP"/>
        <TextView
            android:textSize="14sp"
            android:textColor="?attr/colorOnPrimary"
            android:id="@+id/txt_status"
            android:background="@drawable/bg_ticket_status_success"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@string/font_roboto_medium"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/img_product"/>
        <TextView
            android:textSize="18sp"
            android:textColor="?attr/colorOnSurface"
            android:ellipsize="end"
            android:id="@+id/txt_title"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:lines="2"
            android:fontFamily="@string/font_roboto_medium"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/txt_status"
            app:layout_constraintStart_toEndOf="@+id/img_product"
            app:layout_constraintTop_toTopOf="@+id/img_product"/>
        <TextView
            android:textSize="14sp"
            android:ellipsize="end"
            android:id="@+id/txt_description"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:fontFamily="@string/font_roboto"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/img_product"
            app:layout_constraintTop_toBottomOf="@+id/txt_title"/>
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/bar_ticket_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="txt_description, img_product"/>
        <ImageView
            android:layout_gravity="top"
            android:id="@+id/img_dash_top"
            android:background="@drawable/dotted_line"
            android:layout_width="0px"
            android:layout_height="5dp"
            android:layerType="software"
            app:layout_constraintBottom_toTopOf="@+id/frm_alert_section"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/frm_alert_section"/>
        <ImageView
            android:layout_gravity="top"
            android:id="@+id/img_dash_bottom"
            android:background="@drawable/dotted_line"
            android:layout_width="0px"
            android:layout_height="5dp"
            android:layerType="software"
            app:layout_constraintBottom_toBottomOf="@+id/frm_alert_section"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/frm_alert_section"/>
        <FrameLayout
            android:id="@+id/frm_alert_section"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/bar_ticket_header">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cns_ticket_alert"
                android:background="@color/colorError"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/img_alert_icon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="18dp"
                    android:layout_marginStart="24dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/ic_alarm_on_48dp"/>
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cns_event_begin"
                    android:layout_width="0px"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/img_alert_icon"
                    app:layout_constraintTop_toTopOf="parent">
                    <TextView
                        android:textSize="36sp"
                        android:textColor="?attr/colorOnPrimary"
                        android:id="@+id/txt_event_begin_mins"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="60"
                        android:fontFamily="@string/font_roboto_medium"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <TextView
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnPrimary"
                        android:id="@+id/txt_event_begin_mins_label"
                        android:layout_width="0px"
                        android:layout_height="wrap_content"
                        android:text="@string/Mins"
                        android:fontFamily="@string/font_roboto_medium"
                        android:layout_marginStart="4dp"
                        app:layout_constraintBaseline_toBaselineOf="@+id/txt_event_begin_mins"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/txt_event_begin_mins"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnPrimary"
                        android:id="@+id/txt_event_begin_description"
                        android:layout_width="0px"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/this_event_is_starting_soon"
                        android:fontFamily="@string/font_roboto_medium"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/txt_event_begin_mins"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cns_ticket_more_info"
                android:background="@color/colorError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/img_more_info_icon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="18dp"
                    android:scaleType="center"
                    android:layout_marginStart="24dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/ic_ticket_will_start_40dp"/>
                <TextView
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnPrimary"
                    android:id="@+id/txt_more_info_description"
                    android:layout_width="0px"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="18dp"
                    android:text="@string/this_event_will_start_on_x_at_x"
                    android:fontFamily="@string/font_roboto_medium"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="24dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/img_more_info_icon"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </FrameLayout>
        <TextView
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:id="@+id/lbl_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/date_colon"
            android:fontFamily="@string/font_roboto"
            android:layout_marginStart="18dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/frm_alert_section"
            app:layout_goneMarginTop="16dp"/>
        <TextView
            android:textSize="18sp"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/txt_date"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:fontFamily="@string/font_roboto_medium"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/lbl_date"
            app:layout_goneMarginTop="16dp"/>
        <TextView
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:id="@+id/lbl_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/Location_colon"
            android:fontFamily="@string/font_roboto"
            android:layout_marginStart="18dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txt_date"
            app:layout_goneMarginTop="16dp"/>
        <TextView
            android:textSize="18sp"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/txt_location"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:fontFamily="@string/font_roboto_medium"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/lbl_location"
            app:layout_goneMarginTop="16dp"/>
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@+id/gud_50"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="0.5"/>
        <TextView
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:id="@+id/lbl_time"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/time_colon"
            android:fontFamily="@string/font_roboto"
            android:layout_marginStart="18dp"
            app:layout_constraintEnd_toStartOf="@+id/gud_50"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txt_location"
            app:layout_goneMarginTop="16dp"/>
        <TextView
            android:textSize="18sp"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/txt_time"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:fontFamily="@string/font_roboto_medium"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            app:layout_constraintEnd_toStartOf="@+id/gud_50"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/lbl_time"
            app:layout_goneMarginTop="16dp"/>
        <TextView
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:id="@+id/lbl_quantity"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/Quantity_colon"
            android:fontFamily="@string/font_roboto"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/gud_50"
            app:layout_constraintTop_toBottomOf="@+id/txt_location"
            app:layout_goneMarginTop="16dp"/>
        <TextView
            android:textSize="18sp"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/txt_quantity"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:fontFamily="@string/font_roboto_medium"
            android:layout_marginEnd="18dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/gud_50"
            app:layout_constraintTop_toBottomOf="@+id/lbl_quantity"
            app:layout_goneMarginTop="16dp"/>
        <TextView
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:id="@+id/lbl_price"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/price_colon"
            android:fontFamily="@string/font_roboto"
            android:layout_marginStart="18dp"
            app:layout_constraintEnd_toStartOf="@+id/gud_50"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txt_time"
            app:layout_goneMarginTop="16dp"/>
        <TextView
            android:textSize="18sp"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/txt_price"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:fontFamily="@string/font_roboto_medium"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            app:layout_constraintEnd_toStartOf="@+id/gud_50"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/lbl_price"
            app:layout_goneMarginTop="16dp"/>
        <ImageView
            android:id="@+id/img_qr"
            android:layout_width="0px"
            android:layout_height="0px"
            android:layout_marginTop="32dp"
            android:scaleType="fitCenter"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txt_price"
            app:layout_constraintWidth_percent="0.5"/>
        <TextView
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/txt_slot_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="18dp"
            android:fontFamily="@string/font_roboto"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/img_qr"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>

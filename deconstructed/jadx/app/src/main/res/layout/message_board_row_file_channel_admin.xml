<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="start"
    android:id="@+id/root_view"
    android:paddingTop="@dimen/channel_reply_message_item_padding_top"
    android:paddingBottom="@dimen/channel_reply_message_item_padding_bottom"
    android:focusable="true"
    android:clickable="true"
    android:descendantFocusability="blocksDescendants"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:foreground="@drawable/message_board_selected_row">
    <de.hdodenhof.circleimageview.CircleImageView
        android:layout_gravity="start"
        android:id="@+id/profile_icon"
        android:background="?attr/selectableItemBackground"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:duplicateParentState="true"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="@dimen/channel_admin_chat_space"
        android:layout_marginEnd="@dimen/channel_admin_chat_space"
        app:srcCompat="@drawable/ic_contact_130dp"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/body_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/header_name_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <github.ankushsachdeva.emojicon.EmojiconTextView
                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"
                android:ellipsize="end"
                android:gravity="start"
                android:layout_gravity="start"
                android:id="@+id/group_name"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="3dp"
                android:text="@string/app_name"
                android:lines="1"
                android:fontFamily="@string/font_roboto_medium"
                app:emojiconSize="16sp"/>
            <TextView
                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                android:textSize="16sp"
                android:ellipsize="end"
                android:gravity="start"
                android:layout_gravity="start"
                android:id="@+id/dot_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="3dp"
                android:text="."
                android:lines="1"
                android:fontFamily="@string/font_roboto"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"/>
            <github.ankushsachdeva.emojicon.EmojiconTextView
                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:ellipsize="end"
                android:gravity="start"
                android:layout_gravity="start"
                android:id="@+id/profile_name"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="3dp"
                android:text="@string/app_name"
                android:lines="1"
                android:fontFamily="@string/font_roboto"
                app:emojiconSize="14sp"/>
        </LinearLayout>
        <ImageView
            android:id="@+id/message_board_big_image"
            android:visibility="gone"
            android:layout_width="@dimen/chat_file_item_width"
            android:layout_height="130dp"
            android:layout_marginBottom="2dp"
            android:scaleType="centerCrop"/>
        <RelativeLayout
            android:orientation="horizontal"
            android:id="@+id/content_view"
            android:layout_width="@dimen/chat_file_item_width"
            android:layout_height="wrap_content">
            <FrameLayout
                android:id="@+id/icon_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="6dp">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/message_board_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:srcCompat="@drawable/ic_insert_file_56_dp"/>
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/message_board_retry_icon"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:srcCompat="@drawable/ic_file_upload_56_dp"/>
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_gravity="center"
                    android:id="@+id/spinner"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:indicatorSize="45dp"
                    app:trackColor="@android:color/transparent"/>
            </FrameLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/file_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:layout_marginBottom="3dp"
                android:minWidth="100dp"
                android:layout_toStartOf="@null"
                android:layout_toEndOf="@+id/icon_view">
                <TextView
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnSurface"
                    android:id="@+id/file_name_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:singleLine="true"
                    android:fontFamily="@string/font_roboto"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_gravity="start"
                    android:id="@+id/file_size_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="20kp"
                    android:fontFamily="@string/font_roboto"/>
            </LinearLayout>
        </RelativeLayout>
        <include
            android:id="@+id/footer_view_item"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            layout="@layout/message_board_footer_row_channel_admin"/>
        <com.nandbox.view.util.chatMenu.ChatMenuLayout
            android:orientation="vertical"
            android:id="@+id/inline_menu_view"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"/>
        <com.google.android.material.divider.MaterialDivider
            android:layout_gravity="start"
            android:id="@+id/line_separator"
            android:layout_width="@dimen/channel_reply_message_item_line_separator_width"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"/>
    </LinearLayout>
</LinearLayout>

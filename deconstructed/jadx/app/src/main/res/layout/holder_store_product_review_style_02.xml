<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:elevation="1dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="0dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@+id/gud_50"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="0.3"/>
        <TextView
            android:textSize="48sp"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/txt_rate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@string/font_roboto_medium"
            app:layout_constraintEnd_toEndOf="@+id/gud_50"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/ll_stars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="@+id/gud_50"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txt_rate">
            <ImageView
                android:id="@+id/img_star_1"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:scaleType="centerInside"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                app:srcCompat="@drawable/ic_star_filled_24dp"/>
            <ImageView
                android:id="@+id/img_star_2"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:scaleType="centerInside"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                app:srcCompat="@drawable/ic_star_filled_24dp"/>
            <ImageView
                android:id="@+id/img_star_3"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:scaleType="centerInside"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                app:srcCompat="@drawable/ic_star_filled_24dp"/>
            <ImageView
                android:id="@+id/img_star_4"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:scaleType="centerInside"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                app:srcCompat="@drawable/ic_star_filled_24dp"/>
            <ImageView
                android:id="@+id/img_star_5"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:scaleType="centerInside"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                app:srcCompat="@drawable/ic_star_half_24dp"/>
        </LinearLayout>
        <TextView
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:id="@+id/txt_number_of_reviews"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="37dp"
            android:fontFamily="@string/font_roboto"
            android:textAlignment="center"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/gud_50"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ll_stars"/>
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/bar_stars_text_end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="end"
            app:constraint_referenced_ids="txt_star_5, txt_star_4, txt_star_3, txt_star_2, txt_star_1"/>
        <TextView
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/txt_star_5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/number_5"
            android:fontFamily="@string/font_roboto_medium"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@+id/gud_50"
            app:layout_constraintTop_toTopOf="parent"/>
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/prgrs_star_5"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:progress="37"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:indicatorColor="@color/colorRating5Stars"
            app:indicatorTrackGapSize="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/txt_star_5"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/bar_stars_text_end"
            app:layout_constraintTop_toTopOf="@+id/txt_star_5"
            app:trackColor="@color/colorRatingTrackColor"
            app:trackCornerRadius="90dp"
            app:trackStopIndicatorSize="0px"
            app:trackThickness="8dp"
            style="@style/Widget.Material3.LinearProgressIndicator"/>
        <TextView
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/txt_star_4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/number_4"
            android:fontFamily="@string/font_roboto_medium"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@+id/gud_50"
            app:layout_constraintTop_toBottomOf="@+id/txt_star_5"/>
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/prgrs_star_4"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:progress="37"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:indicatorColor="@color/colorRating4Stars"
            app:indicatorTrackGapSize="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/txt_star_4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/bar_stars_text_end"
            app:layout_constraintTop_toTopOf="@+id/txt_star_4"
            app:trackColor="@color/colorRatingTrackColor"
            app:trackCornerRadius="90dp"
            app:trackStopIndicatorSize="0px"
            app:trackThickness="8dp"
            style="@style/Widget.Material3.LinearProgressIndicator"/>
        <TextView
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/txt_star_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/number_3"
            android:fontFamily="@string/font_roboto_medium"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@+id/gud_50"
            app:layout_constraintTop_toBottomOf="@+id/txt_star_4"/>
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/prgrs_star_3"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:progress="37"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:indicatorColor="@color/colorRating3Stars"
            app:indicatorTrackGapSize="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/txt_star_3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/bar_stars_text_end"
            app:layout_constraintTop_toTopOf="@+id/txt_star_3"
            app:trackColor="@color/colorRatingTrackColor"
            app:trackCornerRadius="90dp"
            app:trackStopIndicatorSize="0px"
            app:trackThickness="8dp"
            style="@style/Widget.Material3.LinearProgressIndicator"/>
        <TextView
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/txt_star_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/number_2"
            android:fontFamily="@string/font_roboto_medium"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@+id/gud_50"
            app:layout_constraintTop_toBottomOf="@+id/txt_star_3"/>
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/prgrs_star_2"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:progress="37"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:indicatorColor="@color/colorRating2Stars"
            app:indicatorTrackGapSize="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/txt_star_2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/bar_stars_text_end"
            app:layout_constraintTop_toTopOf="@+id/txt_star_2"
            app:trackColor="@color/colorRatingTrackColor"
            app:trackCornerRadius="90dp"
            app:trackStopIndicatorSize="0px"
            app:trackThickness="8dp"
            style="@style/Widget.Material3.LinearProgressIndicator"/>
        <TextView
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurface"
            android:id="@+id/txt_star_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"
            android:text="@string/number_1"
            android:fontFamily="@string/font_roboto_medium"
            android:layout_marginStart="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/gud_50"
            app:layout_constraintTop_toBottomOf="@+id/txt_star_2"
            app:layout_constraintVertical_bias="0"/>
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/prgrs_star_1"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:progress="37"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:indicatorColor="@color/colorRating1Stars"
            app:indicatorTrackGapSize="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/txt_star_1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/bar_stars_text_end"
            app:layout_constraintTop_toTopOf="@+id/txt_star_1"
            app:trackColor="@color/colorRatingTrackColor"
            app:trackCornerRadius="90dp"
            app:trackStopIndicatorSize="0px"
            app:trackThickness="8dp"
            style="@style/Widget.Material3.LinearProgressIndicator"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>

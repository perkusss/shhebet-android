<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:background="?attr/selectableItemBackground"
    android:focusable="false"
    android:clickable="false"
    android:descendantFocusability="blocksDescendants"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <FrameLayout
            android:layout_gravity="center_vertical"
            android:id="@+id/image_container"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:paddingTop="11dp"
            android:paddingBottom="11dp"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="14dp">
            <de.hdodenhof.circleimageview.CircleImageView
                android:layout_gravity="center"
                android:id="@+id/img_icon"
                android:layout_width="54dp"
                android:layout_height="54dp"
                app:srcCompat="@drawable/ic_contact_130dp"/>
        </FrameLayout>
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/img_type"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="1dp"
                    android:layout_marginEnd="8dp"
                    android:layout_alignParentStart="true"
                    app:srcCompat="@drawable/ic_bot_18dp"
                    app:tint="?attr/colorOnSurfaceVariant"/>
                <FrameLayout
                    android:id="@+id/contact_name_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@+id/img_type">
                    <TextView
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        android:ellipsize="end"
                        android:layout_gravity="start"
                        android:id="@+id/txt_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Melissa Brewer"
                        android:lines="1"
                        android:singleLine="true"
                        android:textDirection="firstStrong"/>
                </FrameLayout>
            </RelativeLayout>
            <github.ankushsachdeva.emojicon.EmojiconTextView
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:ellipsize="end"
                android:layout_gravity="bottom"
                android:id="@+id/txt_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aw dang. I wish I could."
                android:maxLines="1"
                android:singleLine="true"
                android:textDirection="locale"/>
            <github.ankushsachdeva.emojicon.EmojiconTextView
                android:textSize="14sp"
                android:ellipsize="end"
                android:layout_gravity="bottom"
                android:id="@+id/txt_description2"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aw dang. I wish I could."
                android:maxLines="1"
                android:singleLine="true"
                android:textDirection="locale"/>
        </LinearLayout>
    </LinearLayout>
    <View
        android:id="@+id/separator1"
        android:layout_width="0px"
        android:layout_height="1px"
        android:layout_marginStart="81dp"
        app:dividerColor="?attr/colorOutlineVariant"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>

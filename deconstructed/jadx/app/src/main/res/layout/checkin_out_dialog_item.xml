<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="70dp">
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/checkinout_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginLeft="8dp"
        android:layout_marginStart="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:id="@+id/checkinout_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:layout_marginTop="12dp"
        android:fontFamily="sans-serif"
        android:layout_marginStart="5dp"
        app:layout_constraintStart_toEndOf="@+id/checkinout_icon"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/flagIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="@+id/checkinout_name"
        app:layout_constraintTop_toBottomOf="@+id/checkinout_name"
        app:srcCompat="@drawable/ic_check_in_24_px"/>
    <TextView
        android:textSize="14sp"
        android:textStyle="normal"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:id="@+id/checkInOutTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/_8dp"
        android:fontFamily="sans-serif"
        android:layout_marginStart="@dimen/_8dp"
        app:layout_constraintBottom_toTopOf="@+id/flagIcon"
        app:layout_constraintStart_toEndOf="@+id/flagIcon"
        app:layout_constraintTop_toBottomOf="@+id/flagIcon"/>
    <com.google.android.material.divider.MaterialDivider
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginRight="2dp"
        android:layout_marginEnd="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/flagIcon"/>
</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginRight="4dp"
        android:layout_marginBottom="4dp"
        android:layout_marginHorizontal="4dp"
        android:layout_marginVertical="4dp"
        app:contentPadding="0dp"
        app:layout_constraintBottom_toTopOf="@+id/error_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/image_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:foreground="?attr/selectableItemBackgroundBorderless">
            <androidx.cardview.widget.CardView
                android:layout_gravity="center"
                android:id="@+id/image_container"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/content_image"
                    android:background="?attr/colorSurfaceContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:srcCompat="@drawable/ic_voice_48dp"/>
            </androidx.cardview.widget.CardView>
            <TextView
                android:textStyle="normal"
                android:ellipsize="end"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginRight="8dp"
                android:lines="1"
                android:fontFamily="@string/font_roboto_medium"
                android:layout_marginHorizontal="8dp"
                app:layout_constraintBottom_toTopOf="@+id/desc"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/image_container"
                app:layout_constraintVertical_chainStyle="packed"
                app:layout_goneMarginBottom="8dp"/>
            <TextView
                android:textStyle="normal"
                android:ellipsize="end"
                android:id="@+id/desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="8dp"
                android:layout_marginBottom="8dp"
                android:maxLines="2"
                android:fontFamily="@string/font_roboto"
                android:layout_marginHorizontal="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/title"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <FrameLayout
            android:layout_gravity="end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp">
            <com.google.android.material.button.MaterialButton
                android:ellipsize="end"
                android:id="@+id/select_button"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lines="1"
                app:icon="@drawable/ic_add_18dp"
                app:iconTint="@android:color/white"
                style="@style/Widget.Material3.Button.IconButton.Filled"/>
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_gravity="center"
                android:id="@+id/progress"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:max="100"
                app:indicatorColor="@android:color/white"
                app:indicatorSize="36dp"
                app:trackColor="@android:color/transparent"
                app:trackThickness="2dp"/>
        </FrameLayout>
        <TextView
            android:textSize="12sp"
            android:textColor="?attr/colorOnError"
            android:gravity="center"
            android:layout_gravity="end|top"
            android:id="@+id/unread_count_text"
            android:background="@drawable/circle_red_bg"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="6dp"
            android:minWidth="25dp"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"/>
    </com.google.android.material.card.MaterialCardView>
    <TextView
        android:textSize="16sp"
        android:textStyle="normal"
        android:textColor="?attr/colorError"
        android:gravity="start"
        android:id="@+id/error_text"
        android:visibility="visible"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:lines="1"
        android:fontFamily="@string/font_roboto"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/card_view"
        app:layout_constraintStart_toStartOf="@+id/card_view"/>
</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" android:color="?attr/colorSurface">
    <item android:id="@+id/ripple_mask">
        <shape android:shape="oval">
            <stroke
                android:width="1dp"
                android:color="?attr/colorOutlineVariant"
                android:dashWidth="5dp"
                android:dashGap="5dp"/>
            <padding
                android:left="5dp"
                android:top="5dp"
                android:right="5dp"
                android:bottom="5dp"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</ripple>
